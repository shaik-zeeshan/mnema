---
import "../styles/global.css";
import "@fontsource-variable/hanken-grotesk";
import "@fontsource/spline-sans-mono/400.css";
import "@fontsource/spline-sans-mono/500.css";
import { STABLE_FEED_URL } from "../config";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "mnema — perfect, private memory for your Mac",
  description = "Mnema records your screen, audio, and activity into a private, searchable record you can scrub, search, and ask an AI about — all on your Mac.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL("/icon.png", Astro.site)} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta name="twitter:card" content="summary" />
    <meta name="mnema-latest-release-feed" content={STABLE_FEED_URL} />
    <link rel="icon" type="image/png" href="/icon.png" />
    <script is:inline>
      (function () {
        var t =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark");
        document.documentElement.setAttribute("data-theme", t);
        // Gates the scroll-reveal hidden state in global.css, so content is
        // never invisible when JS doesn't run.
        document.documentElement.classList.add("js");
      })();
    </script>
    <script is:inline>
      // Download links are static (the promote workflow keeps a fixed
      // stable/Mnema.dmg object current), so the only live bit left is the
      // footer version chip, read from the stable update feed. The feed is the
      // published stable channel by construction — no prerelease filtering.
      async function loadLatestVersion() {
        const feedUrl = document.querySelector(
          'meta[name="mnema-latest-release-feed"]',
        )?.content;
        if (!feedUrl) return;

        try {
          const response = await fetch(feedUrl);
          if (!response.ok) return;

          const feed = await response.json();
          if (typeof feed?.version !== "string" || !feed.version) return;
          document.querySelectorAll("[data-latest-release-version]").forEach((el) => {
            el.textContent = `v${feed.version}`;
          });
        } catch {
          // Keep the static "latest" fallback when the feed is unreachable.
        }
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", loadLatestVersion, { once: true });
      } else {
        loadLatestVersion();
      }
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        var els = document.querySelectorAll("[data-reveal]");
        if (!els.length) return;
        if (
          !("IntersectionObserver" in window) ||
          window.matchMedia("(prefers-reduced-motion: reduce)").matches
        ) {
          els.forEach(function (el) {
            el.classList.add("is-revealed");
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-revealed");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -8% 0px" },
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
