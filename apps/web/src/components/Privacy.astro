---
const points = [
  {
    label: "Stays on your Mac",
    detail:
      "Capture, text extraction, transcription, and search all run on-device. No account, no servers, no telemetry — there's no Mnema cloud to send anything to.",
  },
  {
    label: "Secrets auto-redacted",
    detail:
      "Passwords, keys, and tokens are detected and stripped from your record's searchable text — so neither an AI model nor a connected tool ever sees them.",
  },
  {
    label: "Encrypted at rest",
    detail:
      "Your record is encrypted on disk, so it's protected even if your machine isn't.",
  },
  {
    label: "You choose what's kept",
    detail:
      "Keep history forever or auto-delete after 7, 14, or 30 days. It's your call, changeable any time.",
  },
  {
    label: "Delete in one click",
    detail:
      "Wipe the last few minutes of capture instantly, or clear the AI's entire understanding of you — without losing your recordings.",
  },
  {
    label: "Hide anything sensitive",
    detail:
      "Exclude any app from recording, or pause capture entirely whenever you want privacy.",
  },
];
---

<section class="privacy" id="privacy">
  <div class="section-inner">
    <p class="kicker">// private by construction</p>
    <h2 class="section-heading">It all stays on your machine.</h2>
    <p class="section-sub">
      Privacy isn't a setting you switch on. It's how Mnema is built. Recording,
      reading text from your screen, transcribing audio, and search all happen
      on your Mac — and you hold every control.
    </p>

    <ul class="privacy-list">
      {
        points.map((point) => (
          <li class="privacy-item">
            <span class="privacy-marker" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
            <div class="privacy-content">
              <strong class="privacy-label">{point.label}</strong>
              <span class="privacy-detail">{point.detail}</span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .privacy {
    padding: var(--space-2xl) var(--space-lg);
    background: var(--surface);
  }

  .section-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .section-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xs);
    max-width: 20ch;
  }

  .section-sub {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    max-width: 55ch;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .privacy-list {
    list-style: none;
    display: grid;
    gap: var(--space-xs);
    max-width: 36rem;
  }

  .privacy-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-sm);
    align-items: start;
    padding: var(--space-xs) 0;
  }

  .privacy-marker {
    color: var(--accent);
    display: flex;
    margin-top: 0.1rem;
  }

  .privacy-content {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .privacy-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--fg);
  }

  .privacy-detail {
    color: var(--fg-muted);
    font-size: var(--text-xs);
    line-height: 1.55;
  }
</style>
