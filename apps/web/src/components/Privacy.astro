---
const points = [
  {
    key: "local",
    label: "Stays on your Mac",
    detail:
      "Capture, text extraction, transcription, and search all run on-device. No account, no servers, no telemetry. There's no Mnema cloud to send anything to.",
  },
  {
    key: "redact",
    label: "Secrets auto-redacted",
    detail:
      "Passwords, keys, and tokens are detected and stripped from your record's searchable text, so neither an AI model nor a connected tool ever sees them.",
  },
  {
    key: "encrypt",
    label: "Encrypted at rest",
    detail:
      "Your record is encrypted on disk, so it's protected even if your machine isn't.",
  },
  {
    key: "retain",
    label: "You choose what's kept",
    detail:
      "Keep history forever or auto-delete after 7, 14, or 30 days. It's your call, changeable any time.",
  },
  {
    key: "delete",
    label: "Delete in one click",
    detail:
      "Wipe the last few minutes of capture instantly, or clear the AI's entire understanding of you, without losing your recordings.",
  },
  {
    key: "exclude",
    label: "Hide anything sensitive",
    detail:
      "Exclude any app from recording, or pause capture entirely whenever you want privacy.",
  },
];
---

<section class="privacy" id="privacy">
  <div class="section-inner">
    <div class="privacy-story">
      <div class="story-copy" data-reveal>
        <p class="kicker">// private by construction</p>
        <h2 class="section-heading">It all stays on your machine.</h2>
        <p class="section-sub">
          Privacy isn't a setting you switch on. It's how Mnema is built.
          Recording, reading text from your screen, transcribing audio, and
          search all happen on your Mac, and you hold every control.
        </p>
        <p class="privacy-claim">Nothing leaves. Not to us, not to anyone.</p>
      </div>

      <figure
        class="net-readout"
        aria-hidden="true"
        data-reveal
        style="--reveal-delay: 0.1s"
      >
        <div class="net-head">
          <span class="net-title">network monitor</span>
          <span class="net-status"><span class="net-dot"></span>live</span>
        </div>
        <svg class="net-graph" viewBox="0 0 260 44" preserveAspectRatio="none">
          <line class="net-grid" x1="0" y1="10" x2="260" y2="10"></line>
          <line class="net-grid" x1="0" y1="21" x2="260" y2="21"></line>
          <line class="net-flat" x1="0" y1="32" x2="260" y2="32"></line>
        </svg>
        <div class="net-row">
          <span class="net-key">outbound</span>
          <span class="net-fill"></span>
          <span class="net-value">0 bytes</span>
        </div>
        <div class="net-row">
          <span class="net-key">connections</span>
          <span class="net-fill"></span>
          <span class="net-value">0</span>
        </div>
      </figure>
    </div>

    <ol class="privacy-ledger">
      {
        points.map((point, i) => (
          <li
            class="ledger-row"
            data-reveal
            style={`--reveal-delay: ${(i * 0.06).toFixed(2)}s`}
          >
            <span class="ledger-key" aria-hidden="true">
              [{point.key}]
            </span>
            <div class="ledger-content">
              <h3 class="ledger-label">{point.label}</h3>
              <p class="ledger-detail">{point.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .privacy {
    padding: var(--space-2xl) var(--space-lg);
    background: var(--surface);
    border-block: 1px solid var(--border);
  }

  .section-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: var(--space-2xl) var(--space-xl);
    align-items: start;
  }

  .privacy-story {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .section-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
    max-width: 16ch;
    line-height: 1.1;
  }

  .section-sub {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    max-width: 48ch;
    line-height: 1.65;
  }

  .privacy-claim {
    margin-top: var(--space-md);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--fg);
    max-width: 24ch;
    line-height: 1.35;
  }

  /* Ambient element: a calm network readout showing the flat line. */
  .net-readout {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg);
    padding: var(--space-md);
    max-width: 22rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .net-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .net-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .net-status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .net-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: net-pulse 2.4s ease-in-out infinite;
  }

  @keyframes net-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .net-dot {
      animation: none;
    }
  }

  .net-graph {
    width: 100%;
    height: 44px;
    display: block;
  }

  .net-grid {
    stroke: var(--border);
    stroke-width: 1;
    stroke-dasharray: 2 5;
  }

  .net-flat {
    stroke: var(--accent);
    stroke-width: 1.5;
  }

  .net-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .net-key {
    color: var(--fg-muted);
  }

  .net-fill {
    flex: 1;
    border-bottom: 1px dashed var(--border);
    transform: translateY(-3px);
  }

  .net-value {
    color: var(--fg);
  }

  /* The six guarantees as a keyed mono ledger. */
  .privacy-ledger {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--border-strong);
  }

  .ledger-row {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: var(--space-md);
    align-items: baseline;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border);
  }

  .ledger-key {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .ledger-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .ledger-label {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
    line-height: 1.3;
  }

  .ledger-detail {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    max-width: 52ch;
  }

  @media (max-width: 880px) {
    .section-inner {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .net-readout {
      max-width: 26rem;
    }

    .ledger-row {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }
  }
</style>
