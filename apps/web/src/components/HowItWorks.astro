---
const steps = [
  {
    index: "01",
    label: "record",
    description:
      "Mnema runs in the background, capturing your screen, what you hear and say, and which apps you use. It pauses itself when you step away, and you can pause it or hide any app any time.",
  },
  {
    index: "02",
    label: "recall",
    description:
      "Summon a search bar from anywhere and find any moment in seconds — by what was on screen, what was said, or which app you were in. Scrub your whole day back to the exact frame.",
  },
  {
    index: "03",
    label: "reason",
    description:
      "Ask plain-language questions about your past, answered from your own history. Over time, Mnema builds a private picture of how you actually spend your time.",
  },
];
---

<section class="how-it-works" id="how-it-works">
  <div class="section-inner">
    <p class="kicker">// how it works</p>
    <h2 class="section-heading">It records. You recall. The AI reasons.</h2>

    <ol class="steps">
      {
        steps.map((step) => (
          <li class="step">
            <span class="step-index">{step.index}</span>
            <div class="step-content">
              <h3 class="step-label">{step.label}</h3>
              <p class="step-desc">{step.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how-it-works {
    padding: var(--space-2xl) var(--space-lg);
  }

  .section-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .section-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-lg);
  }

  .steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .step-index {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--border-strong);
    font-weight: 600;
    line-height: 1;
  }

  .step-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .step-label {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--fg);
  }

  .step-desc {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    max-width: 55ch;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
