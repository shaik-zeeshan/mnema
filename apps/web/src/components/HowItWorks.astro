---
const steps = [
  {
    index: "01",
    label: "record",
    status: "● rec",
    description:
      "Mnema runs in the background, capturing your screen, what you hear and say, and which apps you use. It pauses itself when you step away, and you can pause it or hide any app any time.",
  },
  {
    index: "02",
    label: "recall",
    status: "⌕ query",
    description:
      "Summon a search bar from anywhere and find any moment in seconds: by what was on screen, what was said, or which app you were in. Scrub your whole day back to the exact frame.",
  },
  {
    index: "03",
    label: "reason",
    status: "∴ answer",
    description:
      "Ask plain-language questions about your past, answered from your own history. Over time, Mnema builds a private picture of how you actually spend your time.",
  },
];
---

<section class="how-it-works" id="how-it-works">
  <div class="section-inner">
    <header class="section-header" data-reveal>
      <p class="kicker">// how it works</p>
      <h2 class="section-heading">It records. You recall. The AI reasons.</h2>
    </header>

    <div class="rail">
      <div class="track" aria-hidden="true">
        <span class="track-pulse"></span>
      </div>

      <ol class="pipeline">
        {
          steps.map((step, i) => (
            <li
              class={`stage stage--${step.label}`}
              data-reveal
              style={`--reveal-delay: ${i * 0.1}s`}
            >
              <span class="node" aria-hidden="true"></span>
              <div class="stage-body">
                <span class="stage-status">{step.status}</span>
                <div class="stage-head">
                  <span class="stage-index" aria-hidden="true">
                    {step.index}
                  </span>
                  <h3 class="stage-label">{step.label}</h3>
                </div>
                <p class="stage-desc">{step.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: var(--space-2xl) var(--space-lg);
  }

  .section-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: var(--space-xl);
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .section-heading {
    font-size: var(--text-3xl);
    line-height: 1.1;
    max-width: 24ch;
  }

  /* The rail: one continuous track the three stages hang off. */
  .rail {
    position: relative;
  }

  /* Mono tick marks running along the track. */
  .rail::before {
    content: "";
    position: absolute;
    top: 1px;
    left: 0;
    right: 0;
    height: 7px;
    background: repeating-linear-gradient(
      90deg,
      var(--border-strong) 0 1px,
      transparent 1px 4rem
    );
    pointer-events: none;
  }

  .track {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 9px;
    overflow: hidden;
    pointer-events: none;
  }

  .track::before {
    content: "";
    position: absolute;
    top: 4px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border);
  }

  .track-pulse {
    position: absolute;
    top: 3px;
    left: 0;
    height: 3px;
    width: 22%;
    border-radius: 2px;
    background: linear-gradient(90deg, transparent, var(--accent));
    box-shadow: 0 0 12px var(--accent-glow);
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .track-pulse {
      animation: pulse-travel 7s linear infinite;
    }
  }

  @keyframes pulse-travel {
    0% {
      transform: translateX(-100%);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    82% {
      opacity: 1;
    }
    100% {
      transform: translateX(460%);
      opacity: 0;
    }
  }

  .pipeline {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr 1.35fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .stage {
    position: relative;
    padding-top: calc(9px + var(--space-md));
  }

  /* Node sitting on the track. bg fill masks the line passing behind it. */
  .node {
    position: absolute;
    top: 0;
    left: 0;
    width: 9px;
    height: 9px;
    border-radius: 2px;
    background: var(--bg);
    border: 1px solid var(--border-strong);
  }

  .stage-status {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    margin-bottom: var(--space-sm);
  }

  .stage--record .stage-status {
    color: var(--accent);
  }

  .stage-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .stage-index {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 600;
    line-height: 1;
    color: var(--border-strong);
  }

  .stage-label {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--fg);
  }

  .stage-desc {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    max-width: 42ch;
    line-height: 1.6;
  }

  /* Stage 03 is the payoff: it gets the dominant, carded treatment. */
  .stage--reason .stage-body {
    background: var(--surface);
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: 0 0 32px var(--accent-glow);
  }

  .stage--reason .node {
    border-color: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow);
  }

  .stage--reason .stage-status {
    color: var(--accent);
  }

  .stage--reason .stage-index {
    font-size: var(--text-display);
    color: var(--accent);
    opacity: 0.85;
  }

  .stage--reason .stage-desc {
    font-size: var(--text-base);
  }

  @media (max-width: 860px) {
    .pipeline {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    /* Track turns vertical down the left edge. */
    .track {
      top: 0;
      bottom: 0;
      left: 0;
      right: auto;
      width: 9px;
      height: auto;
    }

    .track::before {
      top: 0;
      bottom: 0;
      left: 4px;
      right: auto;
      width: 1px;
      height: auto;
    }

    .track-pulse {
      display: none;
    }

    .rail::before {
      top: 0;
      bottom: 0;
      left: 1px;
      right: auto;
      width: 7px;
      height: auto;
      background: repeating-linear-gradient(
        180deg,
        var(--border-strong) 0 1px,
        transparent 1px 3rem
      );
    }

    .stage {
      padding-top: 0;
      padding-left: calc(9px + var(--space-lg));
    }

    .node {
      top: 4px;
    }
  }
</style>
