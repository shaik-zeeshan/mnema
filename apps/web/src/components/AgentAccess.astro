---
import { GITHUB_OWNER, GITHUB_REPO } from "../config";

const repoSlug = `${GITHUB_OWNER}/${GITHUB_REPO}`;
const skillsCliUrl = "https://github.com/vercel-labs/skills";
const skillsCliCommand = `npx skills@latest add ${repoSlug}`;

const installLines = [
  `/plugin marketplace add ${repoSlug}`,
  "/plugin install mnema-data@mnema",
  "/reload-plugins",
];

const usageLines = [
  "mnema access request --scope last-day --duration 24h",
  'mnema search --query "launch notes" --format json',
  "mnema show-text <result-id>",
  "mnema open <result-id>",
];
---

<section class="agent-access" id="agent-access">
  <div class="section-inner">
    <div class="section-copy">
      <p class="kicker">// downstream access</p>
      <h2 class="section-heading">Recall from agents and the terminal.</h2>
      <p class="section-sub">
        Mnema is not only a desktop timeline. Approved local tools can search
        redacted history through the same brokered access layer. Two steps to
        wire it up.
      </p>
    </div>

    <ol class="setup-steps">
      <li class="setup-step">
        <div class="step-head">
          <span class="step-num" aria-hidden="true">01</span>
          <h3>Install the <code>mnema</code> CLI</h3>
        </div>
        <p>
          In Mnema, open <strong>Settings &rarr; Access</strong> and install the
          CLI. Mnema installs the <code>mnema</code> command in its managed CLI
          directory, usually <code>~/.local/bin</code> on macOS and Linux. If that
          directory is not on your shell PATH yet, Settings will show the follow-up.
          Grants are read-only, time-bounded, and approved per client from inside the app.
        </p>
      </li>

      <li class="setup-step">
        <div class="step-head">
          <span class="step-num" aria-hidden="true">02</span>
          <h3>Add the <code>mnema-data</code> skill to your agent</h3>
        </div>
        <p>In <strong>Claude Code</strong>, install it from the Mnema marketplace:</p>
        <div class="terminal-panel" aria-label="Claude Code skill install">
          <div class="terminal-top">
            <span class="terminal-dot" aria-hidden="true"></span>
            <span>claude code</span>
          </div>
          <ol class="command-list">
            {
              installLines.map((line) => (
                <li>
                  <span class="prompt" aria-hidden="true">
                    &gt;
                  </span>
                  <code>{line}</code>
                </li>
              ))
            }
          </ol>
        </div>
        <p class="step-aside">
          Using Codex, Cursor, OpenCode, or PI? Install it in one command with
          the open-source <a href={skillsCliUrl}>skills</a> CLI:
        </p>
        <div class="terminal-panel" aria-label="skills CLI install">
          <div class="terminal-top">
            <span class="terminal-dot" aria-hidden="true"></span>
            <span>terminal</span>
          </div>
          <ol class="command-list">
            <li>
              <span class="prompt" aria-hidden="true">$</span>
              <code>{skillsCliCommand}</code>
            </li>
          </ol>
        </div>
        <p class="step-aside">
          The skill always goes through the CLI, never direct database or media
          reads.
        </p>
      </li>
    </ol>

    <div class="usage">
      <p class="usage-label">// then ask your agent for things like</p>
      <div class="terminal-panel" aria-label="Mnema CLI examples">
        <div class="terminal-top">
          <span class="terminal-dot" aria-hidden="true"></span>
          <span>mnema cli</span>
        </div>
        <ol class="command-list">
          {
            usageLines.map((line) => (
              <li>
                <span class="prompt" aria-hidden="true">
                  $
                </span>
                <code>{line}</code>
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <p class="boundary">
      Read-only and revocable. Every grant is time-bounded and brokered through
      the same privacy policy as the app &mdash; all retained history requires
      explicit approval.
    </p>
  </div>
</section>

<style>
  .agent-access {
    padding: var(--space-2xl) var(--space-lg);
  }

  .section-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  .section-copy {
    max-width: 45rem;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .section-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xs);
    max-width: 24ch;
  }

  .section-sub {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    max-width: 55ch;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .setup-steps {
    list-style: none;
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .setup-step {
    display: grid;
    gap: var(--space-sm);
    padding: var(--space-md);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: border-color 0.3s var(--ease-out-quart);
  }

  .setup-step:hover {
    border-color: var(--border-strong);
  }

  .step-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .step-num {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--border-strong);
    line-height: 1;
  }

  .step-head h3 {
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .setup-step p {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    max-width: 60ch;
  }

  .setup-step code,
  .step-head code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--fg);
  }

  .setup-step strong {
    color: var(--fg);
    font-weight: 500;
  }

  .step-aside {
    font-size: var(--text-sm);
  }

  .step-aside a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
  }

  .step-aside a:hover {
    border-bottom-color: var(--accent);
  }

  .step-aside a code {
    color: inherit;
  }

  .terminal-panel {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    overflow: hidden;
  }

  .terminal-top {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.65rem;
    border-bottom: 1px solid var(--border);
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
  }

  .terminal-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .command-list {
    list-style: none;
    display: grid;
    gap: 0.35rem;
    padding: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .command-list li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.45rem;
    align-items: start;
    min-width: 0;
    color: var(--fg);
  }

  .prompt {
    color: var(--accent);
  }

  .command-list code {
    min-width: 0;
    color: var(--fg-muted);
    overflow-wrap: anywhere;
  }

  .usage {
    display: grid;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .usage-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .boundary {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    max-width: 62ch;
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);
  }
</style>
