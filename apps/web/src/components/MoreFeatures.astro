---
const features = [
  {
    label: "journal",
    detail:
      "Play any day back like a receipt: what you did, hour by hour, with real thumbnails from your own screen.",
  },
  {
    label: "who said what",
    detail:
      "Meetings get speaker labels, worked out on your Mac, and you can match voices to people you name.",
  },
  {
    label: "search by meaning",
    detail:
      "Find things by what they were about, not just the exact words. Download one small model and it works on-device.",
  },
  {
    label: "back to the page",
    detail:
      "Mnema can remember which page you were on and reopen the exact tab in your browser.",
  },
  {
    label: "your own tools",
    detail:
      "Plug your own tools into Ask AI through MCP, so answers can draw on more than your history.",
  },
  {
    label: "cloud transcription · opt-in",
    detail:
      "Want higher-accuracy transcripts? Use your own Deepgram account. Audio leaves your Mac only if you turn this on.",
  },
  {
    label: "low-disk safety",
    detail:
      "Running out of space? Recording pauses itself and picks back up when there's room again.",
  },
  {
    label: "auto-updates",
    detail: "Mnema keeps itself current in the background.",
  },
];
---

<section class="more-features">
  <div class="section-inner">
    <header class="section-header" data-reveal>
      <p class="kicker">// and quietly, more</p>
      <h2 class="section-heading">The small things add up.</h2>
    </header>

    <ol class="manifest" data-reveal style="--reveal-delay: 0.1s">
      {
        features.map((feature, i) => (
          <li class="entry">
            <span class="entry-index" aria-hidden="true">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="entry-label">{feature.label}</h3>
            <p class="entry-detail">{feature.detail}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .more-features {
    padding: var(--space-2xl) var(--space-lg);
  }

  .section-inner {
    max-width: var(--container-text);
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: var(--space-lg);
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .section-heading {
    font-size: var(--text-2xl);
  }

  .manifest {
    list-style: none;
    margin: 0;
    padding: 0;
    border-bottom: 1px solid var(--border);
  }

  .entry {
    display: grid;
    grid-template-columns: 2.5rem 13rem 1fr;
    align-items: baseline;
    gap: var(--space-sm) var(--space-md);
    padding: var(--space-sm) 0;
    border-top: 1px solid var(--border);
    transition: border-color 0.25s var(--ease-out-quart);
  }

  .entry:hover {
    border-top-color: var(--border-strong);
  }

  .entry-index {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    opacity: 0.6;
    transition: color 0.25s var(--ease-out-quart), opacity 0.25s var(--ease-out-quart);
  }

  .entry:hover .entry-index {
    color: var(--accent);
    opacity: 1;
  }

  .entry-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--fg);
  }

  .entry-detail {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .entry {
      grid-template-columns: 2.5rem 1fr;
    }
    .entry-detail {
      grid-column: 2;
    }
  }
</style>
