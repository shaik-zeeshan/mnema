---
import { getImage } from "astro:assets";
import { DOWNLOAD_URL, GITHUB_URL, PLATFORM_LABEL } from "../config";
import screenshotDark from "../assets/screenshot-dark.png";
import screenshotLight from "../assets/screenshot-light.png";

const darkScreenshot = await getImage({
  src: screenshotDark,
  width: 1800,
  format: "webp",
});
const lightScreenshot = await getImage({
  src: screenshotLight,
  width: 1800,
  format: "webp",
});
---

<section class="hero">
  <div class="hero-frags" aria-hidden="true">
    <span class="frag frag-1">09:41:07 · figma</span>
    <span class="frag frag-2">14:22 · terminal · zsh</span>
    <span class="frag frag-3">seg 0412 · ocr ok</span>
    <span class="frag frag-4">11:03:56 · safari</span>
    <span class="frag frag-5">mic · 48kHz</span>
    <span class="frag frag-6">16:48 · slack · #design</span>
  </div>

  <div class="hero-inner">
    <p class="kicker" data-reveal>// total recall · fully private</p>
    <h1 class="headline" data-reveal style="--reveal-delay: 0.08s">
      Perfect memory for everything you've seen, heard, and done.
    </h1>
    <p class="subhead" data-reveal style="--reveal-delay: 0.16s">
      Mnema quietly records your screen, audio, and activity, then lets you
      search it, scrub back to any moment, and ask an AI about your own past.
      All of it stays on your Mac.
    </p>
    <div class="hero-actions" data-reveal style="--reveal-delay: 0.24s">
      <a href={DOWNLOAD_URL} class="btn-primary">
        Download for {PLATFORM_LABEL.split(" · ")[0]}
        <span class="btn-platform">{PLATFORM_LABEL.split(" · ")[1]}</span>
      </a>
      <a href={GITHUB_URL} class="btn-secondary" target="_blank" rel="noopener noreferrer">
        View source
      </a>
    </div>
  </div>

  <div class="hero-showcase">
    <div class="showcase-glow" aria-hidden="true"></div>
    <div class="showcase-shell">
      <p class="showcase-bar">
        <span class="bar-group">
          <span class="showcase-dot" aria-hidden="true"></span>
          <span class="bar-rec">rec</span>
          <span class="bar-sep" aria-hidden="true">·</span>
          screen · audio · activity
        </span>
        <span class="bar-group bar-right">local · 0 bytes leave this Mac</span>
      </p>
      <picture
        class="showcase-picture"
        data-dark-src={darkScreenshot.src}
        data-light-src={lightScreenshot.src}
      >
        <img
          src={darkScreenshot.src}
          width={darkScreenshot.attributes.width}
          height={darkScreenshot.attributes.height}
          alt="Mnema recording and timeline interface on macOS"
          loading="eager"
          decoding="async"
          class="showcase-img"
        />
      </picture>
    </div>
  </div>
</section>

<script>
  const showcase = document.querySelector<HTMLPictureElement>(".showcase-picture");
  const showcaseImg = showcase?.querySelector<HTMLImageElement>(".showcase-img");

  function syncShowcaseImage() {
    const theme = document.documentElement.getAttribute("data-theme");
    const nextSrc =
      theme === "light" ? showcase?.dataset.lightSrc : showcase?.dataset.darkSrc;

    if (showcaseImg && nextSrc && showcaseImg.currentSrc !== nextSrc) {
      showcaseImg.src = nextSrc;
    }
  }

  syncShowcaseImage();

  new MutationObserver(syncShowcaseImage).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });
</script>

<style>
  .hero {
    position: relative;
    padding: calc(64px + var(--space-2xl)) var(--space-lg) var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    overflow: hidden;
  }

  /* Ambient mono metadata fragments: memory, hinted at, never shouting. */
  .hero-frags {
    position: absolute;
    inset: 0;
    pointer-events: none;
    user-select: none;
  }

  .frag {
    position: absolute;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    opacity: 0.22;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .frag-1 { top: 22%; left: 8%; }
  .frag-2 { top: 38%; left: 4%; opacity: 0.14; }
  .frag-3 { top: 55%; left: 10%; opacity: 0.18; }
  .frag-4 { top: 24%; right: 7%; }
  .frag-5 { top: 42%; right: 4%; opacity: 0.14; }
  .frag-6 { top: 58%; right: 9%; opacity: 0.18; }

  .hero-inner {
    max-width: 46rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    position: relative;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .headline {
    font-size: var(--text-display);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--fg);
    max-width: 18ch;
    text-wrap: balance;
  }

  .subhead {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: 48ch;
    line-height: 1.6;
    margin-top: var(--space-xs);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-top: var(--space-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--bg);
    background: var(--accent);
    padding: 0.7rem 1.4rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: box-shadow 0.3s var(--ease-out-quart),
      opacity 0.2s var(--ease-out-quart),
      transform 0.25s var(--ease-out-quart);
  }

  .btn-primary:hover {
    text-decoration: none;
    box-shadow: 0 0 28px var(--accent-glow);
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .btn-platform {
    font-size: var(--text-xs);
    opacity: 0.7;
  }

  .btn-secondary {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    padding: 0.7rem 1.1rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s var(--ease-out-quart),
      border-color 0.2s var(--ease-out-quart),
      transform 0.25s var(--ease-out-quart);
  }

  .btn-secondary:hover {
    color: var(--fg);
    border-color: var(--fg-muted);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .hero-showcase {
    position: relative;
    width: 100%;
    max-width: var(--container-wide);
    margin: 0 auto;
    perspective: 1400px;
  }

  .showcase-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85%;
    height: 80%;
    background: radial-gradient(
      ellipse,
      var(--accent-glow) 0%,
      transparent 68%
    );
    filter: blur(72px);
    pointer-events: none;
  }

  .showcase-shell {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    box-shadow: 0 12px 64px rgba(0, 0, 0, 0.28),
      0 2px 12px rgba(0, 0, 0, 0.08);
    margin: 0 var(--space-lg);
    animation: showcase-settle 1.1s var(--ease-out-expo) 0.15s both;
  }

  @keyframes showcase-settle {
    from {
      opacity: 0;
      transform: rotateX(7deg) translateY(28px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: rotateX(0deg) translateY(0) scale(1);
    }
  }

  /* Terminal-style status strip: real app chrome, machine voice. */
  .showcase-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.05em;
    background: color-mix(in srgb, var(--bg) 60%, var(--surface));
  }

  .bar-group {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .bar-rec {
    color: var(--accent);
  }

  .bar-sep {
    opacity: 0.5;
  }

  .bar-right {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .showcase-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    animation: hero-pulse 2s ease-in-out infinite;
  }

  .showcase-picture {
    display: block;
  }

  .showcase-img {
    width: 100%;
    height: auto;
    display: block;
  }

  @keyframes hero-pulse {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 0 0 var(--accent-glow);
    }
    50% {
      opacity: 0.6;
      box-shadow: 0 0 8px 3px var(--accent-glow);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-dot {
      animation: none;
    }

    .showcase-shell {
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .hero-frags {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: calc(56px + var(--space-xl));
    }

    .headline {
      max-width: 100%;
    }

    .subhead {
      font-size: var(--text-base);
    }

    .showcase-shell {
      margin: 0;
    }

    .bar-right {
      display: none;
    }
  }
</style>
