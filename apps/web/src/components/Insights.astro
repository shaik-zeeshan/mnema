---
const conclusions = [
  {
    text: "You've been heads-down on the Q3 dashboard launch for two weeks straight.",
    because: "// based on 14h in Figma, Linear, and 6 launch meetings",
  },
  {
    text: "Your deepest focus is in the morning. Afternoons skew toward meetings and Slack.",
    because: "// based on 9 days of activity",
  },
];

const subjects = [
  { label: "local-first sync", points: "0,12 8,9 16,6 24,3 32,1", trend: "rising" },
  { label: "type systems", points: "0,2 8,4 16,7 24,9 32,11", trend: "cooling" },
];

const benefits = [
  {
    label: "always-on usage",
    detail:
      "See time per app and site, when you're busiest, and how you hop between tools, without lifting a finger.",
  },
  {
    label: "in your own words",
    detail:
      "Tell Mnema about yourself and what you're working on, and its picture of you sharpens.",
  },
  {
    label: "yours to correct",
    detail:
      "Pin what's right, dismiss what's noise, and correct how it reads your day, or wipe its whole understanding without touching a single recording.",
  },
];
---

<section class="insights" id="insights">
  <div class="section-inner">
    <header class="insights-header" data-reveal>
      <div class="insights-heading-block">
        <p class="kicker">// insights</p>
        <h2 class="section-heading">
          An AI that actually understands your work.
        </h2>
      </div>
      <p class="section-sub">
        From everything it records, Mnema builds a quiet, private picture of
        how you spend your time: the projects you're deep in, where your focus
        goes, and what you keep coming back to. It's yours to read, correct, or
        wipe.
      </p>
    </header>

    <div class="insights-grid">
      <!-- Panel A: conclusions (the dossier proper) -->
      <div class="panel panel-conclusions" data-reveal style="--reveal-delay: 0.08s">
        <div class="panel-chrome" aria-hidden="true">
          <div class="panel-dots"><span></span><span></span><span></span></div>
          <span class="panel-title">mnema · dossier</span>
        </div>
        <div class="panel-body">
          <p class="panel-eyebrow" aria-hidden="true">// conclusions about you</p>
          <ul class="conclusions">
            {
              conclusions.map((c) => (
                <li class="conclusion">
                  <p class="conclusion-text">{c.text}</p>
                  <p class="conclusion-because" aria-hidden="true">
                    {c.because}
                  </p>
                  <div class="conclusion-acts" aria-hidden="true">
                    <span class="act act-pin">pin</span>
                    <span class="act">dismiss</span>
                  </div>
                </li>
              ))
            }
          </ul>
          <p class="panel-caption" aria-hidden="true">
            // pin what rings true, dismiss what doesn't. It won't come back.
          </p>
        </div>
      </div>

      <!-- Panel B: subject sparklines -->
      <div
        class="panel panel-subjects"
        data-reveal
        style="--reveal-delay: 0.16s"
        aria-hidden="true"
      >
        <div class="panel-body">
          <p class="panel-eyebrow">// subjects you keep returning to</p>
          <ul class="subjects">
            {
              subjects.map((s) => (
                <li class="subject">
                  <div class="subject-head">
                    <span class="subject-label">{s.label}</span>
                    <span class:list={["subject-trend", s.trend]}>
                      {s.trend}
                    </span>
                  </div>
                  <svg
                    class="subject-spark"
                    viewBox="0 0 32 13"
                    preserveAspectRatio="none"
                    role="presentation"
                  >
                    <polyline
                      points={s.points}
                      pathLength="1"
                      fill="none"
                      stroke="var(--accent)"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      vector-effect="non-scaling-stroke"
                    />
                  </svg>
                </li>
              ))
            }
          </ul>
          <p class="panel-caption">
            // conviction rises and falls as your attention shifts
          </p>
        </div>
      </div>

      <!-- Benefits strip -->
      <ul class="insight-benefits" data-reveal style="--reveal-delay: 0.24s">
        {
          benefits.map((benefit) => (
            <li class="insight-benefit">
              <span class="insight-benefit-label">{benefit.label}</span>
              <span class="insight-benefit-detail">{benefit.detail}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .insights {
    padding: var(--space-2xl) var(--space-lg);
    background: var(--surface);
  }

  .section-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  /* Split header: heading left, standfirst right */

  .insights-header {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: var(--space-lg) var(--space-xl);
    align-items: end;
    margin-bottom: var(--space-xl);
  }

  .section-heading {
    font-size: var(--text-2xl);
  }

  .section-sub {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    max-width: 55ch;
    line-height: 1.6;
  }

  /* ── Bento grid: two panels of different sizes + full-width strip ── */

  .insights-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: var(--space-md);
    align-items: stretch;
  }

  .panel {
    min-width: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.2);
  }

  .panel-chrome {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .panel-dots {
    display: flex;
    gap: 5px;
  }

  .panel-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-strong);
  }

  .panel-title {
    font-family: var(--font-mono);
    color: var(--fg-muted);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .panel-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    height: 100%;
  }

  .panel-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }

  .panel-caption {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    margin-top: auto;
  }

  /* Panel A: conclusions */

  .conclusions {
    list-style: none;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-sm);
  }

  .conclusion {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .conclusion-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--fg);
  }

  .conclusion-because {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .conclusion-acts {
    display: flex;
    gap: 0.35rem;
    margin-top: 0.1rem;
  }

  .act {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--fg-muted);
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    letter-spacing: 0.02em;
  }

  .act-pin {
    color: var(--accent);
    border-color: var(--accent-border);
    background: var(--accent-bg);
  }

  /* Panel B: subject sparklines */

  .subjects {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .subject {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .subject-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }

  .subject-label {
    color: var(--fg);
  }

  .subject-trend {
    color: var(--fg-muted);
  }

  .subject-trend.rising {
    color: var(--accent);
  }

  .subject-spark {
    width: 100%;
    height: 30px;
    overflow: visible;
  }

  /* Sparkline draw-in, triggered by the reveal system (JS-gated) */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .panel-subjects .subject-spark polyline {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      transition: stroke-dashoffset 1s var(--ease-out-quart) 0.35s;
    }

    :global(html.js)
      .panel-subjects
      .subject:nth-child(2)
      .subject-spark
      polyline {
      transition-delay: 0.55s;
    }

    :global(html.js) .panel-subjects.is-revealed .subject-spark polyline {
      stroke-dashoffset: 0;
    }
  }

  /* ── Benefits strip: three columns joined by hairline dividers ── */

  .insight-benefits {
    grid-column: 1 / -1;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    padding-top: var(--space-md);
  }

  .insight-benefit {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .insight-benefit + .insight-benefit {
    border-left: 1px solid var(--border);
    padding-left: var(--space-lg);
  }

  .insight-benefit-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--fg);
  }

  .insight-benefit-detail {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .insights-header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .insights-grid {
      grid-template-columns: 1fr;
    }

    .conclusions {
      grid-template-columns: 1fr;
    }

    .insight-benefits {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .insight-benefit + .insight-benefit {
      border-left: 0;
      padding-left: 0;
      border-top: 1px solid var(--border);
      padding-top: var(--space-md);
    }
  }
</style>
