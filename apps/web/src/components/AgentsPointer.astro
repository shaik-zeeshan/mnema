---
---

<section class="agents-pointer">
  <div class="pointer-inner" data-reveal>
    <div class="pointer-copy">
      <p class="pointer-eyebrow">// for power users</p>
      <p class="pointer-line">
        Let your own AI agents and command-line tools search your redacted
        history through a brokered, read-only bridge.
      </p>
    </div>
    <a href="/agents" class="pointer-link">
      <span class="pointer-cue" aria-hidden="true">&gt;</span>
      Read the agent access docs
      <span class="pointer-arrow" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>

<style>
  .agents-pointer {
    padding: var(--space-xl) var(--space-lg);
  }

  .pointer-inner {
    max-width: var(--container-text);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-lg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--surface) 50%, transparent);
    transition:
      border-color 0.3s var(--ease-out-quart),
      background-color 0.3s var(--ease-out-quart),
      transform 0.3s var(--ease-out-quart);
  }

  .pointer-inner:hover {
    border-color: var(--border-strong);
    background: var(--surface);
    transform: translateY(-1px);
  }

  .pointer-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    min-width: 0;
  }

  .pointer-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .pointer-line {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.6;
    max-width: 50ch;
  }

  .pointer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.02em;
    text-decoration: none;
    white-space: nowrap;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-sm);
    background: var(--accent-bg);
    transition:
      border-color 0.25s var(--ease-out-quart),
      box-shadow 0.25s var(--ease-out-quart);
  }

  .pointer-link:hover {
    text-decoration: none;
    border-color: var(--accent-strong);
    box-shadow: 0 0 16px var(--accent-glow);
  }

  .pointer-cue {
    color: var(--accent);
  }

  .pointer-arrow {
    display: inline-block;
    transition: transform 0.25s var(--ease-out-quart);
  }

  .pointer-link:hover .pointer-arrow {
    transform: translateX(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .pointer-inner:hover {
      transform: none;
    }

    .pointer-link:hover .pointer-arrow {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .pointer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
    }
  }
</style>
