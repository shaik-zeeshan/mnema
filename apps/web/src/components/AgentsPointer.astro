---
---

<section class="agents-pointer">
  <div class="pointer-inner">
    <div class="pointer-copy">
      <p class="pointer-eyebrow">// for power users</p>
      <p class="pointer-line">
        Let your own AI agents and command-line tools search your redacted
        history through a brokered, read-only bridge.
      </p>
    </div>
    <a href="/agents" class="pointer-link">
      <span class="pointer-cue" aria-hidden="true">&gt;</span>
      Read the agent access docs
    </a>
  </div>
</section>

<style>
  .agents-pointer {
    padding: var(--space-lg) var(--space-lg);
  }

  .pointer-inner {
    max-width: 56rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 50%, transparent);
    transition: border-color 0.3s var(--ease-out-quart);
  }

  .pointer-inner:hover {
    border-color: var(--border-strong);
  }

  .pointer-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    min-width: 0;
  }

  .pointer-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .pointer-line {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.55;
    max-width: 55ch;
  }

  .pointer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.02em;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s var(--ease-out-quart);
  }

  .pointer-link:hover {
    text-decoration: none;
    opacity: 0.82;
  }

  .pointer-cue {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .pointer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
