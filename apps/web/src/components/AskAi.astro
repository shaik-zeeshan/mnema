---
const benefits = [
  {
    label: "cites its sources",
    detail:
      "Jump from any answer straight to the exact frame or audio clip. No black box — you can always check the receipt.",
  },
  {
    label: "keeps the thread",
    detail:
      "Follow up, refine, and revisit past conversations in a searchable chat workspace that remembers where you left off.",
  },
  {
    label: "your model, your choice",
    detail:
      "Bring your own Anthropic or OpenAI key — or run a fully local model with no account and no key at all.",
  },
];

const citations = [
  { icon: "◷", label: "Zoom · Tue 11:20 AM" },
  { icon: "▤", label: "Figma · Tue 2:41 PM" },
  { icon: "◷", label: "Slack · Wed 9:15 AM" },
];
---

<section class="ask-ai" id="ask-ai">
  <div class="section-inner">
    <p class="kicker">// ask ai</p>
    <h2 class="section-heading">Ask your own memory a question.</h2>
    <p class="section-sub">
      Type a question the way you'd ask a colleague who never forgets. Mnema
      answers from your own history — and every answer links straight to the
      frames and clips it's drawn from, so you can verify it yourself.
    </p>

    <div class="ask-layout">
      <div class="ask-card" aria-hidden="true">
        <div class="ask-chrome">
          <div class="ask-dots"><span></span><span></span><span></span></div>
          <span class="ask-chrome-title">mnema · ask</span>
        </div>

        <div class="ask-body">
          <div class="ask-prompt">
            <span class="ask-prompt-cue">&gt;</span>
            <span class="ask-prompt-text"
              >what did Alice say about the launch deadline last week?</span
            >
          </div>

          <div class="ask-answer">
            <div class="ask-answer-label">
              <span class="ask-live-dot"></span>
              <span>answering</span>
            </div>
            <p class="ask-answer-text">
              Alice said the launch slipped to the 14th so design could finish
              the onboarding flow. She asked you to send the updated copy by
              Thursday.<span class="ask-caret"></span>
            </p>
          </div>

          <div class="ask-cites">
            {
              citations.map((cite) => (
                <span class="ask-chip">
                  <span class="ask-chip-icon">{cite.icon}</span>
                  <span class="ask-chip-label">{cite.label}</span>
                </span>
              ))
            }
          </div>
          <p class="ask-cite-caption">
            // every claim links to the moment it came from
          </p>
        </div>
      </div>

      <ul class="ask-benefits">
        {
          benefits.map((benefit) => (
            <li class="ask-benefit">
              <span class="ask-benefit-label">{benefit.label}</span>
              <span class="ask-benefit-detail">{benefit.detail}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .ask-ai {
    padding: var(--space-2xl) var(--space-lg);
  }

  .section-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .section-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xs);
  }

  .section-sub {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    max-width: 55ch;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .ask-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: var(--space-lg);
    align-items: start;
  }

  /* ── Ask-AI mock card ── */

  .ask-card {
    min-width: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg);
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.3);
  }

  .ask-chrome {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .ask-dots {
    display: flex;
    gap: 5px;
  }

  .ask-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-strong);
  }

  .ask-chrome-title {
    color: var(--fg-muted);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .ask-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ask-prompt {
    display: flex;
    gap: 0.5rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--accent-border);
    background: var(--accent-bg);
    border-radius: var(--radius-sm);
    line-height: 1.5;
  }

  .ask-prompt-cue {
    color: var(--accent);
    flex-shrink: 0;
  }

  .ask-prompt-text {
    color: var(--fg);
    overflow-wrap: anywhere;
  }

  .ask-answer {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ask-answer-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--fg-muted);
    font-size: 0.6rem;
    letter-spacing: 0.04em;
  }

  .ask-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: ask-pulse 2s ease-in-out infinite;
  }

  @keyframes ask-pulse {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 0 0 var(--accent-glow);
    }
    50% {
      opacity: 0.6;
      box-shadow: 0 0 8px 3px var(--accent-glow);
    }
  }

  .ask-answer-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--fg);
    /* stream-in: reveal as a clipped block, then settle */
    opacity: 0;
    animation: ask-stream-in 0.6s var(--ease-out-expo) 0.5s forwards;
  }

  @keyframes ask-stream-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ask-caret {
    display: inline-block;
    width: 0.45em;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent);
    animation: ask-blink 1s step-end infinite;
  }

  @keyframes ask-blink {
    50% {
      opacity: 0;
    }
  }

  .ask-cites {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .ask-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.55rem;
    border: 1px solid var(--accent-border);
    background: var(--accent-bg);
    border-radius: 999px;
    font-size: 0.65rem;
    color: var(--fg);
    opacity: 0;
    transform: translateY(6px);
  }

  .ask-cites .ask-chip:nth-child(1) {
    animation: ask-chip-in 0.5s var(--ease-out-expo) 1.1s forwards;
  }

  .ask-cites .ask-chip:nth-child(2) {
    animation: ask-chip-in 0.5s var(--ease-out-expo) 1.3s forwards;
  }

  .ask-cites .ask-chip:nth-child(3) {
    animation: ask-chip-in 0.5s var(--ease-out-expo) 1.5s forwards;
  }

  @keyframes ask-chip-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ask-chip-icon {
    color: var(--accent);
    flex-shrink: 0;
  }

  .ask-cite-caption {
    color: var(--fg-muted);
    font-size: 0.6rem;
    letter-spacing: 0.02em;
  }

  /* ── Benefit lines ── */

  .ask-benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: var(--space-xs);
  }

  .ask-benefit {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ask-benefit-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--fg);
  }

  .ask-benefit-detail {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  @media (prefers-reduced-motion: reduce) {
    .ask-live-dot {
      animation: none;
    }

    .ask-answer-text {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .ask-caret {
      animation: none;
      opacity: 1;
    }

    .ask-cites .ask-chip {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .ask-layout {
      grid-template-columns: 1fr;
    }

    .ask-card {
      font-size: 0.68rem;
    }
  }
</style>
