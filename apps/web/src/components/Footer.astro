---
import { DOWNLOAD_URL, GITHUB_URL } from "../config";
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-wordmark" aria-label="mnema home">
          <img
            src="/icon.png"
            alt=""
            width="20"
            height="20"
            class="footer-icon"
          />
          <span class="footer-name">mnema</span>
        </a>
        <span class="footer-version" data-latest-release-version>latest</span>
      </div>

      <nav class="footer-links" aria-label="Footer">
        <a href={DOWNLOAD_URL}>Download</a>
        <a href="/pricing">Pricing</a>
        <a href="/agents">Agents</a>
        <a href="/alternatives/rewind-ai">Rewind alternative</a>
        <a href="/alternatives/microsoft-recall-mac">Recall for Mac</a>
        <a href="/alternatives/screenpipe">Screenpipe alternative</a>
        <a href="/alternatives/limitless">Limitless alternative</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a
          href={`${GITHUB_URL}/blob/main/LICENSE`}
          target="_blank"
          rel="noopener noreferrer">AGPL-3.0 License</a
        >
      </nav>
    </div>

    <p class="footer-copy">
      <span class="footer-copy-cue" aria-hidden="true">//</span>
      everything stays on your machine.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: var(--space-xl) var(--space-lg);
    margin-top: var(--space-xl);
  }

  .footer-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .footer-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer-wordmark {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    color: var(--fg);
  }

  .footer-wordmark:hover {
    text-decoration: none;
  }

  .footer-icon {
    border-radius: 4px;
  }

  .footer-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .footer-version {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--fg-muted);
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    row-gap: var(--space-sm);
    column-gap: var(--space-lg);
  }

  .footer-links a {
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s var(--ease-out-quart);
  }

  .footer-links a:hover {
    color: var(--fg);
    text-decoration: none;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    border-top: 1px solid var(--border);
    padding-top: var(--space-md);
  }

  .footer-copy-cue {
    color: var(--accent);
    margin-right: 0.2rem;
  }

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-links {
      flex-wrap: wrap;
      gap: var(--space-md);
    }
  }
</style>
