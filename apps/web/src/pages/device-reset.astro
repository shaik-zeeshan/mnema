---
// Support note for the license device cap — this is the page the license
// server's `reset_url` points at when an activation is refused with
// "device cap reached". Everything self-service happens inside the app
// ("Free up my devices" in Settings → License); this page just explains it
// for people who land here from the link.
//
// Self-contained on purpose, like /license/open: no Base.astro (its release-fetch
// machinery is dead weight here). Palette mirrors src/styles/tokens.css.
import { GITHUB_URL } from "../config";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Move Mnema to a new Mac</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta
      name="description"
      content="Your Mnema license works on up to 3 Macs. Free them up from inside the app to move to a new one."
    />
    <style>
      :root {
        --bg: #0c0c0e;
        --surface: #14141a;
        --fg: #e2e2e8;
        --fg-muted: #8a8aaa;
        --border: #1e1e2e;
        --accent: #3dffa0;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
        --sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--sans);
      }
      .card {
        width: 100%;
        max-width: 520px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 32px;
      }
      .logo { width: 44px; height: 44px; border-radius: 10px; display: block; }
      h1 { font-size: 22px; margin: 20px 0 8px; }
      p, li { color: var(--fg-muted); font-size: 14px; line-height: 1.6; }
      p { margin: 0 0 16px; }
      ol { margin: 0 0 16px; padding-left: 20px; }
      li { margin-bottom: 6px; }
      .path {
        font-family: var(--mono);
        font-size: 12.5px;
        color: var(--accent);
        white-space: nowrap;
      }
      .fine { font-size: 12.5px; margin-bottom: 0; }
      a { color: var(--fg); }
      a:hover { color: var(--accent); }
      hr { border: none; border-top: 1px solid var(--border); margin: 20px 0; }
    </style>
  </head>
  <body>
    <main class="card">
      <a href="/"><img class="logo" src="/icon.png" alt="Mnema" /></a>
      <h1>Move Mnema to a new Mac</h1>
      <p>
        Your Mnema license works on up to <strong>3 Macs</strong>. If you just tried to activate
        a new one and were told the limit is reached, you can free up your devices yourself —
        right from the app, no forms, no waiting.
      </p>
      <ol>
        <li>Open Mnema on the Mac you want to use.</li>
        <li>Go to <span class="path">Settings → License</span>.</li>
        <li>Click <strong>Free up my devices</strong>.</li>
      </ol>
      <p>
        That one click clears the license's device list and activates the Mac you're on. To keep
        the limit meaningful, it works once every 30 days — if you reset recently, the app shows
        the date it opens up again.
      </p>
      <hr />
      <p class="fine">
        Still stuck? <a href={`${GITHUB_URL}/issues`} target="_blank" rel="noopener noreferrer"
          >Open an issue on GitHub</a
        > and we'll sort it out.
      </p>
    </main>
  </body>
</html>
