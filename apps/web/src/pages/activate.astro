---
// License activation landing page. The email links here with the key in the URL
// *hash* (`/activate#key=…`) — a hash is never sent to the server, so the license
// token stays out of CDN/access logs. Everything below runs client-side off that
// hash: a Copy button (what email bodies can't do — no JS in mail) and an
// "Open Mnema" button firing the `mnema://license/activate` deep link.
//
// Self-contained on purpose: no Base.astro (its release-fetch machinery is dead
// weight here). Palette mirrors src/styles/tokens.css.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Activate Mnema</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta name="robots" content="noindex" />
    <style>
      :root {
        --bg: #0c0c0e;
        --surface: #14141a;
        --fg: #e2e2e8;
        --fg-muted: #8a8aaa;
        --border: #1e1e2e;
        --accent: #3dffa0;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
        --sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--sans);
      }
      .card {
        width: 100%;
        max-width: 460px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 32px;
      }
      .logo { width: 44px; height: 44px; border-radius: 10px; display: block; }
      h1 { font-size: 22px; margin: 20px 0 8px; }
      p { color: var(--fg-muted); font-size: 14px; line-height: 1.6; margin: 0 0 20px; }
      .btn {
        display: block;
        width: 100%;
        border: none;
        border-radius: 10px;
        padding: 13px 20px;
        font-family: var(--sans);
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
      }
      .btn-primary { background: var(--accent); color: var(--bg); }
      .key-row { display: flex; gap: 8px; margin: 20px 0 0; }
      .key {
        flex: 1;
        min-width: 0;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 12px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .btn-copy {
        flex: 0 0 auto;
        width: auto;
        background: transparent;
        color: var(--fg);
        border: 1px solid var(--border);
        font-size: 13px;
        padding: 0 16px;
      }
      .btn-copy.copied { color: var(--accent); border-color: var(--accent); }
      .hint { margin: 12px 0 0; font-size: 12px; }
      .error { color: var(--fg); }
    </style>
  </head>
  <body>
    <main class="card" hidden>
      <img class="logo" src="/icon.png" alt="Mnema" />
      <h1>Activate Mnema</h1>
      <p>Click below to open the app and apply your license.</p>

      <a id="open" class="btn btn-primary" href="#">Open Mnema</a>

      <div class="key-row">
        <div id="key" class="key" title="Your license key">…</div>
        <button id="copy" class="btn btn-copy" type="button">Copy</button>
      </div>
      <p class="hint">
        Didn't open? Copy the key and paste it into <strong>Settings → License</strong>.
      </p>
    </main>

    <script is:inline>
      (function () {
        // Key arrives in the hash: `/activate#key=<url-encoded>`.
        var params = new URLSearchParams((location.hash || "").replace(/^#/, ""));
        var key = params.get("key") || "";
        var keyEl = document.getElementById("key");
        var openEl = document.getElementById("open");
        var copyEl = document.getElementById("copy");

        // No key means someone reached /activate directly (crawler, guessed URL,
        // shared-without-hash). There's nothing to do here — bounce to the site so
        // it never reads as a real, browsable page.
        if (!key) {
          location.replace("/");
          return;
        }

        keyEl.textContent = key;
        openEl.href = "mnema://license/activate?key=" + encodeURIComponent(key);
        document.querySelector(".card").hidden = false;

        copyEl.addEventListener("click", async function () {
          try {
            await navigator.clipboard.writeText(key);
          } catch {
            // Fallback for older/insecure contexts.
            var r = document.createRange();
            r.selectNodeContents(keyEl);
            var sel = window.getSelection();
            sel.removeAllRanges();
            sel.addRange(r);
            document.execCommand("copy");
            sel.removeAllRanges();
          }
          copyEl.textContent = "Copied";
          copyEl.classList.add("copied");
          setTimeout(function () {
            copyEl.textContent = "Copy";
            copyEl.classList.remove("copied");
          }, 1600);
        });
      })();
    </script>
  </body>
</html>
