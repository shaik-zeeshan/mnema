---
// Renewal-return redirect. The Polar renewal product's success URL points here
// because most providers can't emit a custom `mnema://` protocol themselves — so
// they land the browser on `https://mnema.day/license/renewed?checkout_id=…` and
// this page bounces into the `mnema://license/renewed` deep link the desktop app
// handles (a short Receipt Refresh poll).
//
// checkout_id is only a crawler guard here — the machine already holds the key, a
// renewal just extends it server-side, so the deep link carries no payload at all.
//
// Self-contained on purpose (no Base.astro). Palette mirrors src/styles/tokens.css.
//
// Always fires `mnema://` — the release build's scheme. The dev build registers
// `mnema-dev://` (tauri.dev.conf.json), but only a *bundled* app claims a scheme
// with macOS LaunchServices, and `tauri dev` runs an unbundled binary that never
// registers anything. So there is no `mnema-dev://` handler to fire at; to test the
// deep link end-to-end, run a real installed build (`mnema://`).
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mnema license renewed</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta name="robots" content="noindex" />
    <style>
      :root {
        --bg: #0c0c0e;
        --surface: #14141a;
        --fg: #e2e2e8;
        --fg-muted: #8a8aaa;
        --border: #1e1e2e;
        --accent: #3dffa0;
        --sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--sans);
      }
      .card {
        width: 100%;
        max-width: 460px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 32px;
      }
      .logo { width: 44px; height: 44px; border-radius: 10px; display: block; }
      h1 { font-size: 22px; margin: 20px 0 8px; }
      p { color: var(--fg-muted); font-size: 14px; line-height: 1.6; margin: 0 0 20px; }
      .btn {
        display: block;
        width: 100%;
        border: none;
        border-radius: 10px;
        padding: 13px 20px;
        font-family: var(--sans);
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
      }
      .btn-primary { background: var(--accent); color: var(--bg); }
      .hint { margin: 12px 0 0; font-size: 12px; }
    </style>
  </head>
  <body>
    <main class="card" hidden>
      <img class="logo" src="/icon.png" alt="Mnema" />
      <h1>Thanks for renewing Mnema</h1>
      <p>Opening the app to confirm your extended update window…</p>

      <a id="open" class="btn btn-primary" href="#">Open Mnema</a>

      <p class="hint">
        Didn't open? Use the <strong>Refresh license status</strong> button in
        <strong>Settings → License</strong>.
      </p>
    </main>

    <script is:inline>
      (function () {
        var checkoutId = new URLSearchParams(location.search).get("checkout_id") || "";
        var openEl = document.getElementById("open");

        // No id means someone reached /license/renewed directly (crawler, guessed URL).
        // Nothing to confirm — bounce to the site so it never reads as a real page.
        if (!checkoutId) {
          location.replace("/");
          return;
        }

        // No payload on the deep link — the app already holds the key.
        var deepLink = "mnema://license/renewed";
        openEl.href = deepLink;
        document.querySelector(".card").hidden = false;

        // Auto-fire once; the button stays as the manual fallback if the OS blocks it.
        location.href = deepLink;
      })();
    </script>
  </body>
</html>
