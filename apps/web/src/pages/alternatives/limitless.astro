---
import Base from "../../layouts/Base.astro";
import TopBar from "../../components/TopBar.astro";
import Footer from "../../components/Footer.astro";
import { DOWNLOAD_URL, PLATFORM_LABEL } from "../../config";

const pageTitle = "Limitless alternative — Mnema";
const pageDescription =
  "Meta acquired Limitless in December 2025 and Pendant sales stopped. Mnema is a Limitless alternative for Mac: private, on-device memory of your screen and audio — no wearable, no cloud, no subscription.";

const criteria = [
  {
    label: "No cloud dependency",
    detail:
      "Limitless stored your conversations in its cloud — which is why an acquisition could shut the service off in whole regions overnight. A local-first tool keeps working no matter who buys whom.",
  },
  {
    label: "No extra hardware",
    detail:
      "A pendant captures what's said around you. Your Mac already sees your meetings, calls, documents, and browsing — software can remember all of it without another device to charge.",
  },
  {
    label: "More than conversations",
    detail:
      "Meeting transcripts are half the story. The other half is what was on screen: the doc you had open, the numbers you saw, the page you can't find again.",
  },
  {
    label: "You control retention and deletion",
    detail:
      "Keep history forever or auto-delete on a schedule, and delete any stretch of it in one click. Your record, your rules — enforced on your machine, not by a service.",
  },
];

const comparison = {
  columns: ["Mnema", "Limitless Pendant", "Screenpipe"],
  rows: [
    {
      label: "Status",
      cells: [
        "Actively developed",
        "Acquired by Meta — sales ended Dec 2025",
        "Active (agent-focused)",
      ],
    },
    {
      label: "Form factor",
      cells: ["Mac app", "Wearable + cloud app", "Cross-platform app"],
    },
    {
      label: "Where your data lives",
      cells: [
        "On your Mac, encrypted at rest",
        "Limitless / Meta cloud",
        "On your machine",
      ],
    },
    {
      label: "What it captures",
      cells: [
        "Screen, audio, and activity",
        "Spoken conversations",
        "Screen and audio",
      ],
    },
    {
      label: "Ask-AI / chat",
      cells: [
        "Yes — over your own history",
        "Yes (cloud)",
        "Agent-focused (bring your own)",
      ],
    },
    {
      label: "Price",
      cells: [
        "$69 once, 30-day free trial",
        "Hardware discontinued",
        "$25/mo (personal use free)",
      ],
    },
  ],
};

const faqs = [
  {
    q: "What happened to Limitless?",
    a: "Meta acquired Limitless on December 5, 2025. Pendant sales stopped the same day, the service was discontinued in the EU, UK, and several other regions, and the Rewind Mac app was shut down. Existing Pendant owners keep working service for at least a year, with the team folded into Meta's Reality Labs.",
  },
  {
    q: "What is the best Limitless alternative?",
    a: "It depends on what you used it for. If you want a private memory of your work — meetings, calls, documents, everything you saw and heard on your Mac — Mnema covers it on-device with no wearable and no cloud: transcription with speaker labels, timeline scrubbing, search, and ask-AI, encrypted at rest. If you specifically want a wearable for in-person conversations away from your desk, no Mac app replaces that.",
  },
  {
    q: "Does Mnema record meetings like Limitless did?",
    a: "Yes — Mnema records microphone and system audio on your Mac and transcribes it on-device with speaker labels, so calls and meetings become searchable alongside what was on screen at the time. Nothing is uploaded anywhere.",
  },
  {
    q: "Does Mnema send my recordings to the cloud?",
    a: "No. Capture, text extraction, transcription, and search all run on-device — there's no account, no servers, and no telemetry. The one exception is opt-in: you can use your own Deepgram account for higher-accuracy transcripts, and audio leaves your Mac only if you turn that on.",
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
});
---

<Base title={pageTitle} description={pageDescription}>
  <TopBar />
  <main class="docs">
    <article class="docs-col">
      <!-- Hero -->
      <header class="docs-hero">
        <p class="kicker">// limitless alternative</p>
        <h1 class="docs-title">
          A Limitless alternative that no acquisition can switch off.
        </h1>
        <p class="docs-sub">
          Limitless sold a memory that lived in its cloud — and when Meta
          bought the company, whole regions lost it overnight. Mnema is the
          same promise kept differently: a private memory of everything you
          see, hear, and do on your Mac, stored on your Mac, encrypted at
          rest. No wearable, no account, no subscription.
        </p>
        <p class="docs-meta">// reading time ~4 min · macOS · Apple Silicon</p>
      </header>

      <!-- What happened -->
      <section class="docs-section" aria-labelledby="what-happened">
        <p class="kicker">// the short version</p>
        <h2 class="section-heading" id="what-happened">
          What happened to Limitless
        </h2>
        <p class="prose">
          Limitless began life as Rewind, the Mac app that made "a search
          engine for your life" a real product category. In 2024 it pivoted
          to hardware: the Limitless Pendant, a wearable that recorded your
          conversations and summarized them through a cloud service.
        </p>
        <p class="prose">
          On December 5, 2025, Meta acquired the company. Pendant sales ended
          that day. The service was discontinued in the EU, UK, Brazil, and
          several other regions, the old Rewind app was shut down, and
          existing Pendant owners were promised support for at least a year
          while the team joined Meta's Reality Labs.
        </p>
        <p class="prose">
          The lesson isn't that Limitless was a bad product — it's that a
          memory kept in someone else's cloud is only yours until their plans
          change. If you're replacing it, that's the property to fix first.
        </p>
      </section>

      <!-- Criteria -->
      <section class="docs-section" aria-labelledby="criteria">
        <p class="kicker">// choosing a replacement</p>
        <h2 class="section-heading" id="criteria">
          What to look for in a replacement
        </h2>
        <p class="prose">
          A tool that remembers your conversations and your work holds the
          most personal data you have. Four things worth insisting on.
        </p>
        <ul class="criteria-list">
          {
            criteria.map((item) => (
              <li class="criteria-item">
                <span class="criteria-marker" aria-hidden="true">
                  ✓
                </span>
                <div class="criteria-text">
                  <span class="criteria-label">{item.label}</span>
                  <span class="criteria-detail">{item.detail}</span>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Comparison -->
      <section class="docs-section" aria-labelledby="comparison">
        <p class="kicker">// the field</p>
        <h2 class="section-heading" id="comparison">
          Mnema vs Limitless vs Screenpipe
        </h2>
        <p class="prose">
          The core difference isn't features — it's where your memory lives
          and who can take it away.
        </p>
        <div class="table-scroll">
          <table class="compare-table">
            <thead>
              <tr>
                <th scope="col"></th>
                {comparison.columns.map((col) => <th scope="col">{col}</th>)}
              </tr>
            </thead>
            <tbody>
              {
                comparison.rows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    {row.cells.map((cell, i) => (
                      <td class={i === 0 ? "cell-mnema" : undefined}>{cell}</td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="table-note">
          Competitor details reflect public information as of July 2026 —
          check each project directly before deciding.
        </p>
      </section>

      <!-- FAQ -->
      <section class="docs-section" aria-labelledby="faq">
        <p class="kicker">// questions</p>
        <h2 class="section-heading" id="faq">Frequently asked</h2>
        <dl class="faq-list">
          {
            faqs.map((item) => (
              <div class="faq-item">
                <dt>
                  <h3 class="faq-q">{item.q}</h3>
                </dt>
                <dd class="faq-a">{item.a}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- CTA -->
      <section class="docs-section cta" aria-labelledby="cta-heading">
        <p class="kicker">// get started</p>
        <h2 class="section-heading" id="cta-heading">
          A memory nobody can acquire.
        </h2>
        <p class="prose">
          Download Mnema and build a private, searchable memory of your work —
          one you can scrub, search, and ask anything. Open source, free for
          30 days.
        </p>
        <a href={DOWNLOAD_URL} class="btn-primary">
          Download for {PLATFORM_LABEL.split(" · ")[0]}
          <span class="btn-platform">{PLATFORM_LABEL.split(" · ")[1]}</span>
        </a>
      </section>

      <!-- Page footer -->
      <footer class="docs-foot">
        <p class="docs-foot-line">
          // local-first · encrypted at rest · no account, no servers, no
          telemetry — your record never leaves your Mac.
        </p>
        <a href="/" class="docs-back">
          <span class="prompt" aria-hidden="true">&gt;</span>
          <span>Back to mnema</span>
        </a>
      </footer>
    </article>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={faqJsonLd} is:inline />
</Base>

<style>
  /* ---- Docs layout shell (same pattern as rewind-ai.astro) ---- */
  .docs {
    padding: calc(var(--space-2xl) + 3rem) var(--space-lg) var(--space-2xl);
  }

  .docs-col {
    max-width: 52rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  /* ---- Hero ---- */
  .docs-hero {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-xl);
  }

  .docs-title {
    font-family: var(--font-sans);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
    max-width: 24ch;
  }

  .docs-sub {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-base);
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: var(--space-md);
  }

  .docs-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  /* ---- Section shell ---- */
  .docs-section {
    margin-bottom: var(--space-2xl);
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
    max-width: 30ch;
  }

  .prose {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-base);
    line-height: 1.75;
    max-width: 64ch;
  }

  .prose + .prose {
    margin-top: var(--space-md);
  }

  /* ---- Criteria ---- */
  .criteria-list {
    list-style: none;
    display: grid;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .criteria-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-sm);
    align-items: start;
  }

  .criteria-marker {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .criteria-text {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
  }

  .criteria-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    letter-spacing: 0.01em;
  }

  .criteria-detail {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.65;
  }

  /* ---- Comparison table ---- */
  .table-scroll {
    margin-top: var(--space-lg);
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .compare-table {
    width: 100%;
    min-width: 40rem;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .compare-table th,
  .compare-table td {
    padding: 0.65rem 0.85rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--border);
  }

  .compare-table tbody tr:last-child th,
  .compare-table tbody tr:last-child td {
    border-bottom: none;
  }

  .compare-table thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--fg);
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--border-strong);
  }

  .compare-table thead th:first-child {
    color: var(--fg-muted);
  }

  .compare-table tbody th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .compare-table td {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .compare-table td.cell-mnema {
    color: var(--fg);
  }

  .table-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.01em;
    margin-top: var(--space-sm);
    max-width: 70ch;
  }

  /* ---- FAQ ---- */
  .faq-list {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .faq-item {
    display: grid;
    gap: var(--space-xs);
  }

  .faq-q {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .faq-a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 62ch;
  }

  /* ---- CTA ---- */
  .cta .prose {
    margin-bottom: var(--space-md);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--bg);
    background: var(--accent);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition:
      box-shadow 0.3s var(--ease-out-quart),
      transform 0.3s var(--ease-out-quart),
      opacity 0.2s var(--ease-out-quart);
  }

  .btn-primary:hover {
    text-decoration: none;
    box-shadow: 0 0 28px var(--accent-glow);
    transform: translateY(-1px);
    opacity: 0.92;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-primary:hover {
      transform: none;
    }
  }

  .btn-platform {
    font-size: var(--text-xs);
    opacity: 0.7;
  }

  /* ---- Page footer ---- */
  .docs-foot {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
    display: grid;
    gap: var(--space-md);
  }

  .docs-foot-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    line-height: 1.7;
    letter-spacing: 0.01em;
    max-width: 70ch;
  }

  .docs-back {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s var(--ease-out-quart);
  }

  .docs-back:hover {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }

  .prompt {
    color: var(--accent);
  }
</style>
