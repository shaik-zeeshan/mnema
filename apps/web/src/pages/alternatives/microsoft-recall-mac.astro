---
import Base from "../../layouts/Base.astro";
import TopBar from "../../components/TopBar.astro";
import Footer from "../../components/Footer.astro";
import { DOWNLOAD_URL, PLATFORM_LABEL } from "../../config";

const pageTitle = "Microsoft Recall for Mac? Mnema is the Mac equivalent";
const pageDescription =
  "There's no Microsoft Recall for Mac — Recall is a Windows 11 Copilot+ PC feature. Mnema brings the same idea to macOS: continuous capture, searchable screen history, timeline scrubbing, and ask-AI — private and on-device.";

const features = [
  {
    key: "capture",
    label: "Continuous capture",
    detail:
      "Mnema records your screen, audio, and activity into a private personal record — the same always-on snapshot idea Recall promises, running natively on macOS.",
  },
  {
    key: "search",
    label: "Search everything you've seen",
    detail:
      "Text is read from your screen on-device (OCR) and audio is transcribed locally, so you can search anything that ever crossed your screen or your meetings.",
  },
  {
    key: "timeline",
    label: "Scrub the timeline",
    detail:
      "Rewind through your own history like a video — jump to the exact moment you half-remember and see it again.",
  },
  {
    key: "ask",
    label: "Ask AI about your history",
    detail:
      "Ask questions in plain language and get answers grounded in your own record. Local AI agents can get read-only, brokered access too.",
  },
];

const comparisonRows = [
  {
    label: "Platform",
    recall: "Windows 11",
    mnema: "macOS",
    openrecall: "Windows, macOS, Linux",
    screenpipe: "Windows, macOS, Linux",
  },
  {
    label: "Hardware",
    recall: "Copilot+ PC with an NPU",
    mnema: "Apple Silicon Mac",
    openrecall: "Standard hardware",
    screenpipe: "Standard hardware",
  },
  {
    label: "Local-only storage",
    recall: "Yes",
    mnema: "Yes — no account, no cloud",
    openrecall: "Yes",
    screenpipe: "Yes",
  },
  {
    label: "Audio capture",
    recall: "No",
    mnema: "Yes — mic and system audio",
    openrecall: "No",
    screenpipe: "Yes",
  },
  {
    label: "Ask AI over history",
    recall: "Search",
    mnema: "Yes — ask AI, plus agent access",
    openrecall: "Search",
    screenpipe: "Yes — via plugins",
  },
];

const faqs = [
  {
    question: "Does Apple have a Recall feature?",
    answer:
      "No. macOS ships nothing equivalent to Windows Recall. Spotlight searches your files, but nothing built into macOS records what was on your screen or lets you search it later. Mnema is a third-party Mac app that fills exactly that gap.",
  },
  {
    question: "Is Mnema private?",
    answer:
      "Yes. Capture, text extraction, transcription, and search all run on your Mac — no account, no servers, no telemetry, and no Mnema cloud to send anything to. Your record is encrypted at rest, secrets like passwords and keys are auto-redacted, you choose how long history is kept, and you can exclude apps or delete recent capture in one click.",
  },
  {
    question: "Does Mnema work on Intel Macs?",
    answer:
      "Not today. Mnema currently ships builds for Apple Silicon Macs only — there is no Intel build.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<Base title={pageTitle} description={pageDescription}>
  <TopBar />
  <main class="docs">
    <article class="docs-col">
      <!-- Hero -->
      <header class="docs-hero">
        <p class="kicker">// recall, for mac</p>
        <h1 class="docs-title">
          There's no Microsoft Recall for Mac. Mnema is the Mac equivalent.
        </h1>
        <p class="docs-sub">
          Recall is a Windows-only feature, and Apple ships nothing like it.
          Mnema is the same idea — a searchable record of everything you've
          seen — built Mac-native and private: everything stays on your
          machine.
        </p>
        <p class="docs-meta">// macOS · Apple Silicon · free and open source</p>
      </header>

      <!-- Direct answer -->
      <section class="docs-section" aria-labelledby="direct-answer">
        <p class="kicker">// the short answer</p>
        <h2 class="section-heading" id="direct-answer">
          Is there a Microsoft Recall for Mac?
        </h2>
        <p class="prose">
          No. Recall is a Windows 11 feature exclusive to Copilot+ PCs — it
          needs an NPU-equipped machine, where it periodically snapshots your
          screen and makes those snapshots searchable. Apple ships nothing
          equivalent on macOS: no built-in screen history, no "scroll back
          through your day." If you want that on a Mac, it has to come from a
          third-party app.
        </p>
      </section>

      <!-- What Mnema does -->
      <section class="docs-section" aria-labelledby="what-mnema-does">
        <p class="kicker">// the equivalent</p>
        <h2 class="section-heading" id="what-mnema-does">
          What Mnema does on your Mac.
        </h2>
        <p class="prose">
          Mnema covers Recall's promise — and goes further, because it also
          hears what Recall only sees.
        </p>
        <ul class="feature-list">
          {
            features.map((item) => (
              <li class="feature-item">
                <span class="feature-key" aria-hidden="true">
                  [{item.key}]
                </span>
                <div class="feature-text">
                  <h3 class="feature-label">{item.label}</h3>
                  <p class="feature-detail">{item.detail}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Privacy contrast -->
      <section class="docs-section" aria-labelledby="privacy">
        <p class="kicker">// privacy</p>
        <h2 class="section-heading" id="privacy">
          Private by construction, not by patch.
        </h2>
        <p class="prose">
          Recall drew heavy criticism at its 2024 launch for storing screen
          snapshots insecurely. Microsoft delayed it and reworked the design —
          it's now opt-in, gated behind Windows Hello, and encrypted. Fair
          enough; the concerns were addressed after the fact.
        </p>
        <p class="prose">
          Mnema starts from the other end. Capture, text extraction,
          transcription, and search all run on your Mac — no account, no
          servers, no telemetry, no Mnema cloud to send anything to. Your
          record is encrypted at rest, secrets like passwords and keys are
          auto-redacted from searchable text, and you hold every control: keep
          history forever or auto-delete after 7, 14, or 30 days, exclude any
          app from recording, and wipe recent capture in one click.
        </p>
      </section>

      <!-- Comparison table -->
      <section class="docs-section" aria-labelledby="comparison">
        <p class="kicker">// side by side</p>
        <h2 class="section-heading" id="comparison">
          Recall, Mnema, and the open-source options.
        </h2>
        <div class="table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th scope="col"></th>
                <th scope="col">Windows Recall</th>
                <th scope="col" class="col-mnema">Mnema</th>
                <th scope="col">OpenRecall</th>
                <th scope="col">Screenpipe</th>
              </tr>
            </thead>
            <tbody>
              {
                comparisonRows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    <td>{row.recall}</td>
                    <td class="col-mnema">{row.mnema}</td>
                    <td>{row.openrecall}</td>
                    <td>{row.screenpipe}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="table-note">
          Competitor details are kept deliberately general — check each
          project for current specifics.
        </p>
      </section>

      <!-- FAQ -->
      <section class="docs-section" aria-labelledby="faq">
        <p class="kicker">// questions</p>
        <h2 class="section-heading" id="faq">Common questions.</h2>
        <dl class="faq-list">
          {
            faqs.map((faq) => (
              <div class="faq-item">
                <dt>
                  <h3 class="faq-question">{faq.question}</h3>
                </dt>
                <dd class="faq-answer">{faq.answer}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- CTA -->
      <section class="docs-section cta" aria-labelledby="cta-heading">
        <p class="kicker">// get started</p>
        <h2 class="section-heading" id="cta-heading">
          Recall, the Mac way.
        </h2>
        <p class="prose">
          Download Mnema and build a private, searchable memory of your work —
          one you can scrub, search, and ask anything. Free and open source.
        </p>
        <a href={DOWNLOAD_URL} class="btn-primary">
          Download for {PLATFORM_LABEL.split(" · ")[0]}
          <span class="btn-platform">{PLATFORM_LABEL.split(" · ")[1]}</span>
        </a>
      </section>

      <!-- Page footer -->
      <footer class="docs-foot">
        <p class="docs-foot-line">
          // everything on-device: capture, OCR, transcription, search, and
          storage — encrypted at rest, retention and deletion in your hands.
        </p>
        <a href="/" class="docs-back">
          <span class="prompt" aria-hidden="true">&gt;</span>
          <span>Back to mnema</span>
        </a>
      </footer>
    </article>
  </main>
  <Footer />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>

<style>
  /* ---- Docs layout shell (lifted from agents.astro) ---- */
  .docs {
    padding: calc(var(--space-2xl) + 3rem) var(--space-lg) var(--space-2xl);
  }

  .docs-col {
    max-width: 52rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  /* ---- Hero ---- */
  .docs-hero {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-xl);
  }

  .docs-title {
    font-family: var(--font-sans);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
    max-width: 24ch;
    line-height: 1.1;
  }

  .docs-sub {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-base);
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: var(--space-md);
  }

  .docs-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  /* ---- Section shell ---- */
  .docs-section {
    margin-bottom: var(--space-2xl);
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
    max-width: 26ch;
  }

  .prose {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-base);
    line-height: 1.75;
    max-width: 64ch;
  }

  .prose + .prose {
    margin-top: var(--space-md);
  }

  /* ---- Feature list (keyed mono ledger) ---- */
  .feature-list {
    list-style: none;
    margin: var(--space-lg) 0 0;
    padding: 0;
    border-top: 1px solid var(--border-strong);
  }

  .feature-item {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: var(--space-md);
    align-items: baseline;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border);
  }

  .feature-key {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .feature-label {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
    line-height: 1.3;
  }

  .feature-detail {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    max-width: 56ch;
  }

  /* ---- Comparison table ---- */
  .table-wrap {
    margin-top: var(--space-lg);
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .compare-table {
    width: 100%;
    min-width: 44rem;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .compare-table th,
  .compare-table td {
    padding: var(--space-sm) var(--space-md);
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--border);
  }

  .compare-table tbody tr:last-child th,
  .compare-table tbody tr:last-child td {
    border-bottom: none;
  }

  .compare-table thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--fg);
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--border-strong);
    white-space: nowrap;
  }

  .compare-table tbody th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .compare-table td {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .compare-table .col-mnema {
    color: var(--fg);
    background: color-mix(in srgb, var(--accent-bg) 45%, transparent);
  }

  .table-note {
    margin-top: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.01em;
  }

  /* ---- FAQ ---- */
  .faq-list {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .faq-item {
    display: grid;
    gap: var(--space-xs);
  }

  .faq-question {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--fg);
  }

  .faq-answer {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 62ch;
  }

  /* ---- CTA (button lifted from FinalCta) ---- */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--bg);
    background: var(--accent);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    letter-spacing: 0.02em;
    margin-top: var(--space-md);
    transition:
      box-shadow 0.3s var(--ease-out-quart),
      transform 0.3s var(--ease-out-quart),
      opacity 0.2s var(--ease-out-quart);
  }

  .btn-primary:hover {
    text-decoration: none;
    box-shadow: 0 0 28px var(--accent-glow);
    transform: translateY(-1px);
    opacity: 0.92;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-primary:hover {
      transform: none;
    }
  }

  .btn-platform {
    font-size: var(--text-xs);
    opacity: 0.7;
  }

  /* ---- Page footer ---- */
  .docs-foot {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
    display: grid;
    gap: var(--space-md);
  }

  .docs-foot-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    line-height: 1.7;
    letter-spacing: 0.01em;
    max-width: 70ch;
  }

  .docs-back {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s var(--ease-out-quart);
  }

  .docs-back:hover {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }

  .prompt {
    color: var(--accent);
  }

  @media (max-width: 560px) {
    .feature-item {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }
  }
</style>
