---
import Base from "../../layouts/Base.astro";
import TopBar from "../../components/TopBar.astro";
import Footer from "../../components/Footer.astro";
import { DOWNLOAD_URL, PLATFORM_LABEL } from "../../config";

const pageTitle = "Rewind AI alternative for Mac — Mnema";
const pageDescription =
  "Rewind AI shut down in December 2025. Mnema is a Rewind AI alternative for Mac: private, on-device screen and audio memory you can search, scrub, and ask an AI about.";

const criteria = [
  {
    label: "Stays on your Mac",
    detail:
      "Capture, text extraction, transcription, and search should all run on-device, with the record encrypted at rest. If a company can read your history, an acquisition can too.",
  },
  {
    label: "Captures everything you'd want back",
    detail:
      "Screen, audio, and activity — not just screenshots. The moments you need to recall are as often something said in a call as something on screen.",
  },
  {
    label: "Search plus ask-AI",
    detail:
      "Keyword search finds what you can name; asking an AI about your own past finds what you can only half-describe.",
  },
  {
    label: "You control retention and deletion",
    detail:
      "Keep history forever or auto-delete on a schedule, and delete any stretch of it in one click. Your record, your rules.",
  },
];

const comparison = {
  columns: ["Mnema", "Screenpipe", "ScreenMemory", "OpenRecall"],
  rows: [
    {
      label: "Platform",
      cells: ["macOS (Apple Silicon)", "Cross-platform", "macOS", "Cross-platform"],
    },
    {
      label: "Open source",
      cells: ["Yes", "Yes", "No", "Yes"],
    },
    {
      label: "Local-first",
      cells: ["Yes — on-device, encrypted at rest", "Yes", "Yes", "Yes"],
    },
    {
      label: "Audio transcription",
      cells: [
        "Yes — on-device, with speaker labels",
        "Yes",
        "Screen-focused",
        "Screen-focused",
      ],
    },
    {
      label: "Ask-AI / chat",
      cells: ["Yes — over your own history", "Yes (via plugins)", "Varies", "Search-focused"],
    },
    {
      label: "Agent / CLI access",
      cells: ["Yes — brokered, read-only CLI", "Yes (API)", "—", "—"],
    },
    {
      label: "Price",
      cells: ["$69 once, 30-day free trial", "Open source", "Paid", "Free (open source)"],
    },
  ],
};

const faqs = [
  {
    q: "Is Rewind AI still available?",
    a: "No. The Rewind Mac app shut down on December 19, 2025, after Meta acquired Limitless (the company Rewind became). Pendant sales stopped, service was discontinued in the EU and UK, and remaining support winds down through 2026.",
  },
  {
    q: "What is the best Rewind AI alternative for Mac?",
    a: "If you want what Rewind originally promised — a private, searchable record of everything on your Mac — Mnema is the closest match: it captures screen, audio, and activity on-device, encrypts it at rest, and lets you search it, scrub back to any moment, and ask an AI about it. Screenpipe and OpenRecall are open-source, cross-platform options worth a look too.",
  },
  {
    q: "Does Mnema send my recordings to the cloud?",
    a: "No. Capture, text extraction, transcription, and search all run on-device — there's no account, no servers, no telemetry, and no Mnema cloud to send anything to. The one exception is opt-in: you can use your own Deepgram account for higher-accuracy transcripts, and audio leaves your Mac only if you turn that on.",
  },
  {
    q: "Can I still use my Rewind data?",
    a: "Rewind stored its recordings locally, so the files may still be on your Mac — but Mnema does not import Rewind archives. Starting with Mnema means starting a fresh record from the day you install it.",
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
});
---

<Base title={pageTitle} description={pageDescription}>
  <TopBar />
  <main class="docs">
    <article class="docs-col">
      <!-- Hero -->
      <header class="docs-hero">
        <p class="kicker">// rewind ai alternative</p>
        <h1 class="docs-title">
          A private Rewind AI alternative that stays on your Mac.
        </h1>
        <p class="docs-sub">
          Rewind is gone — the Mac app shut down in December 2025. Mnema picks
          up where it left off: a local-first screen memory that quietly records
          your screen, audio, and activity, then lets you search it, scrub back
          to any moment, and ask an AI about your own past. None of it leaves
          your Mac.
        </p>
        <p class="docs-meta">// reading time ~4 min · macOS · Apple Silicon</p>
      </header>

      <!-- What happened -->
      <section class="docs-section" aria-labelledby="what-happened">
        <p class="kicker">// the short version</p>
        <h2 class="section-heading" id="what-happened">
          What happened to Rewind AI
        </h2>
        <p class="prose">
          Rewind launched in late 2022 as a Mac app that recorded your screen
          and audio locally and made it searchable — "the search engine for
          your life." For a while it was the reference point for personal
          screen memory on the Mac.
        </p>
        <p class="prose">
          In 2024 the company rebranded to Limitless and pivoted to a
          cloud-based wearable, the Limitless Pendant. The Mac app stopped
          being the focus.
        </p>
        <p class="prose">
          In December 2025, Meta acquired Limitless. The Rewind Mac app shut
          down on December 19, 2025, Pendant sales stopped, and service was
          discontinued in the EU and UK, with remaining support winding down
          through 2026.
        </p>
        <p class="prose">
          If you relied on Rewind, you're now looking for a replacement — and
          the shutdown itself is a useful lesson in what to look for next.
        </p>
      </section>

      <!-- Criteria -->
      <section class="docs-section" aria-labelledby="criteria">
        <p class="kicker">// choosing a replacement</p>
        <h2 class="section-heading" id="criteria">
          What to look for in a replacement
        </h2>
        <p class="prose">
          A tool that records everything you see and hear is only as good as
          its answer to one question: who else can see it? Four things worth
          insisting on.
        </p>
        <ul class="criteria-list">
          {
            criteria.map((item) => (
              <li class="criteria-item">
                <span class="criteria-marker" aria-hidden="true">
                  ✓
                </span>
                <div class="criteria-text">
                  <span class="criteria-label">{item.label}</span>
                  <span class="criteria-detail">{item.detail}</span>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Comparison -->
      <section class="docs-section" aria-labelledby="comparison">
        <p class="kicker">// the field</p>
        <h2 class="section-heading" id="comparison">
          Mnema vs Screenpipe vs ScreenMemory vs OpenRecall
        </h2>
        <p class="prose">
          These are the main tools people move to after Rewind. All of them
          keep your data local — the differences are in scope and platform.
        </p>
        <div class="table-scroll">
          <table class="compare-table">
            <thead>
              <tr>
                <th scope="col"></th>
                {comparison.columns.map((col) => <th scope="col">{col}</th>)}
              </tr>
            </thead>
            <tbody>
              {
                comparison.rows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    {row.cells.map((cell, i) => (
                      <td class={i === 0 ? "cell-mnema" : undefined}>{cell}</td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="table-note">
          Competitor details reflect public information as of July 2026 —
          check each project directly before deciding.
        </p>
      </section>

      <!-- FAQ -->
      <section class="docs-section" aria-labelledby="faq">
        <p class="kicker">// questions</p>
        <h2 class="section-heading" id="faq">Frequently asked</h2>
        <dl class="faq-list">
          {
            faqs.map((item) => (
              <div class="faq-item">
                <dt>
                  <h3 class="faq-q">{item.q}</h3>
                </dt>
                <dd class="faq-a">{item.a}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- CTA -->
      <section class="docs-section cta" aria-labelledby="cta-heading">
        <p class="kicker">// get started</p>
        <h2 class="section-heading" id="cta-heading">
          Start a record you actually own.
        </h2>
        <p class="prose">
          Download Mnema and build a private, searchable memory of your work —
          one you can scrub, search, and ask anything. Open source, free for
          30 days.
        </p>
        <a href={DOWNLOAD_URL} class="btn-primary">
          Download for {PLATFORM_LABEL.split(" · ")[0]}
          <span class="btn-platform">{PLATFORM_LABEL.split(" · ")[1]}</span>
        </a>
      </section>

      <!-- Page footer -->
      <footer class="docs-foot">
        <p class="docs-foot-line">
          // local-first · encrypted at rest · no account, no servers, no
          telemetry — your record never leaves your Mac.
        </p>
        <a href="/" class="docs-back">
          <span class="prompt" aria-hidden="true">&gt;</span>
          <span>Back to mnema</span>
        </a>
      </footer>
    </article>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={faqJsonLd} is:inline />
</Base>

<style>
  /* ---- Docs layout shell (same pattern as agents.astro) ---- */
  .docs {
    padding: calc(var(--space-2xl) + 3rem) var(--space-lg) var(--space-2xl);
  }

  .docs-col {
    max-width: 52rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  /* ---- Hero ---- */
  .docs-hero {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-xl);
  }

  .docs-title {
    font-family: var(--font-sans);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
    max-width: 24ch;
  }

  .docs-sub {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-base);
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: var(--space-md);
  }

  .docs-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  /* ---- Section shell ---- */
  .docs-section {
    margin-bottom: var(--space-2xl);
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
    max-width: 30ch;
  }

  .prose {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-base);
    line-height: 1.75;
    max-width: 64ch;
  }

  .prose + .prose {
    margin-top: var(--space-md);
  }

  /* ---- Criteria (check-marker list, lifted from agents.astro) ---- */
  .criteria-list {
    list-style: none;
    display: grid;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .criteria-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-sm);
    align-items: start;
  }

  .criteria-marker {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .criteria-text {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
  }

  .criteria-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    letter-spacing: 0.01em;
  }

  .criteria-detail {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.65;
  }

  /* ---- Comparison table ---- */
  .table-scroll {
    margin-top: var(--space-lg);
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .compare-table {
    width: 100%;
    min-width: 40rem;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .compare-table th,
  .compare-table td {
    padding: 0.65rem 0.85rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--border);
  }

  .compare-table tbody tr:last-child th,
  .compare-table tbody tr:last-child td {
    border-bottom: none;
  }

  .compare-table thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--fg);
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--border-strong);
  }

  .compare-table thead th:first-child {
    color: var(--fg-muted);
  }

  .compare-table tbody th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .compare-table td {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .compare-table td.cell-mnema {
    color: var(--fg);
  }

  .table-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.01em;
    margin-top: var(--space-sm);
    max-width: 70ch;
  }

  /* ---- FAQ ---- */
  .faq-list {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .faq-item {
    display: grid;
    gap: var(--space-xs);
  }

  .faq-q {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .faq-a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 62ch;
  }

  /* ---- CTA (button pattern from FinalCta.astro) ---- */
  .cta .prose {
    margin-bottom: var(--space-md);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--bg);
    background: var(--accent);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition:
      box-shadow 0.3s var(--ease-out-quart),
      transform 0.3s var(--ease-out-quart),
      opacity 0.2s var(--ease-out-quart);
  }

  .btn-primary:hover {
    text-decoration: none;
    box-shadow: 0 0 28px var(--accent-glow);
    transform: translateY(-1px);
    opacity: 0.92;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-primary:hover {
      transform: none;
    }
  }

  .btn-platform {
    font-size: var(--text-xs);
    opacity: 0.7;
  }

  /* ---- Page footer ---- */
  .docs-foot {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
    display: grid;
    gap: var(--space-md);
  }

  .docs-foot-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    line-height: 1.7;
    letter-spacing: 0.01em;
    max-width: 70ch;
  }

  .docs-back {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s var(--ease-out-quart);
  }

  .docs-back:hover {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }

  .prompt {
    color: var(--accent);
  }
</style>
