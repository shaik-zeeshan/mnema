---
import Base from "../../layouts/Base.astro";
import TopBar from "../../components/TopBar.astro";
import Footer from "../../components/Footer.astro";
import { DOWNLOAD_URL, PLATFORM_LABEL } from "../../config";

const pageTitle = "Screenpipe alternative for Mac — Mnema";
const pageDescription =
  "Looking for a Screenpipe alternative? Mnema is a fully open-source, one-time-purchase screen memory for Mac: on-device capture, transcription, search, and ask-AI — no subscription.";

const criteria = [
  {
    label: "Built for recall, not agent plumbing",
    detail:
      "If what you want is to find that thing you saw last Tuesday, you want a polished timeline, search, and ask-AI out of the box — not an API you wire agents into first.",
  },
  {
    label: "Actually open source",
    detail:
      "Source-available licenses let you read the code but restrict what you can do with it. A genuinely open-source license means the community can fork, audit, and keep the project alive.",
  },
  {
    label: "Predictable price",
    detail:
      "A subscription for software that runs entirely on your own machine adds up forever. A one-time purchase means the copy you bought keeps working, whatever happens to the company.",
  },
  {
    label: "Stays on your Mac",
    detail:
      "Capture, text extraction, transcription, and search should all run on-device, with the record encrypted at rest. No account, no servers, no telemetry.",
  },
];

const comparison = {
  columns: ["Mnema", "Screenpipe", "OpenRecall"],
  rows: [
    {
      label: "Platform",
      cells: ["macOS (Apple Silicon)", "Cross-platform", "Cross-platform"],
    },
    {
      label: "License",
      cells: [
        "Open source",
        "Source-available (commercial license)",
        "Open source",
      ],
    },
    {
      label: "Local-first",
      cells: ["Yes — on-device, encrypted at rest", "Yes", "Yes"],
    },
    {
      label: "Audio transcription",
      cells: ["Yes — on-device, with speaker labels", "Yes", "Screen-focused"],
    },
    {
      label: "Ask-AI / chat",
      cells: [
        "Yes — over your own history",
        "Agent-focused (bring your own)",
        "Search-focused",
      ],
    },
    {
      label: "Agent / CLI access",
      cells: ["Yes — brokered, read-only CLI", "Yes (API)", "—"],
    },
    {
      label: "Price",
      cells: [
        "$69 once, 30-day free trial",
        "$25/mo (personal use free)",
        "Free (open source)",
      ],
    },
  ],
};

const faqs = [
  {
    q: "Is Screenpipe still open source?",
    a: "Not in the usual sense. Screenpipe launched under the MIT license but later moved to a source-available commercial license: personal, non-commercial use stays free, but commercial use requires a paid license, and the signed desktop app is a subscription starting at $25/month. Mnema is open source, and the app is a one-time $69 purchase.",
  },
  {
    q: "What is the best Screenpipe alternative for Mac?",
    a: "If you want personal recall — a private, searchable record of what you've seen, heard, and done — Mnema is built exactly for that on the Mac: on-device capture, transcription with speaker labels, timeline scrubbing, search, and ask-AI, with the record encrypted at rest. If you mainly want raw screen data piped into your own agents, Screenpipe's API-first approach may still fit better.",
  },
  {
    q: "How is Mnema different from Screenpipe?",
    a: "Screenpipe has evolved into a context layer for AI agents — you record everything and plug the data into agents and integrations. Mnema is a finished personal-memory app: recording, timeline, search, and ask-AI work out of the box with nothing to assemble, and agents are still served through a brokered, read-only CLI when you want them.",
  },
  {
    q: "Does Mnema send my recordings to the cloud?",
    a: "No. Capture, text extraction, transcription, and search all run on-device — there's no account, no servers, and no telemetry. The one exception is opt-in: you can use your own Deepgram account for higher-accuracy transcripts, and audio leaves your Mac only if you turn that on.",
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
});
---

<Base title={pageTitle} description={pageDescription}>
  <TopBar />
  <main class="docs">
    <article class="docs-col">
      <!-- Hero -->
      <header class="docs-hero">
        <p class="kicker">// screenpipe alternative</p>
        <h1 class="docs-title">
          A Screenpipe alternative that's built for recall, not plumbing.
        </h1>
        <p class="docs-sub">
          Screenpipe records everything and hands you the data to build with.
          Mnema records everything and hands you the answers: a Mac-native
          timeline you can scrub, search, and ask an AI about — on-device,
          encrypted at rest, open source, and yours for a one-time purchase.
        </p>
        <p class="docs-meta">// reading time ~4 min · macOS · Apple Silicon</p>
      </header>

      <!-- Where Screenpipe landed -->
      <section class="docs-section" aria-labelledby="what-changed">
        <p class="kicker">// the short version</p>
        <h2 class="section-heading" id="what-changed">
          Where Screenpipe has landed
        </h2>
        <p class="prose">
          Screenpipe earned its following as an open-source, cross-platform
          engine for 24/7 screen and mic capture — the raw material for a
          personal AI, with a plugin system to build on top.
        </p>
        <p class="prose">
          It has since repositioned around AI agents: the pitch today is a
          local-first context layer you plug into agent frameworks and
          integrations. Along the way the license moved from MIT to a
          source-available commercial license, and the signed desktop app
          became a subscription starting at $25/month (personal,
          non-commercial use stays free).
        </p>
        <p class="prose">
          None of that is wrong — it's just a different product than a
          personal memory. If what you wanted was the recall part — find that
          page, replay that meeting, ask what you worked on last week — you're
          assembling it yourself from parts. That's the gap Mnema fills.
        </p>
      </section>

      <!-- Criteria -->
      <section class="docs-section" aria-labelledby="criteria">
        <p class="kicker">// choosing a replacement</p>
        <h2 class="section-heading" id="criteria">
          What to look for in an alternative
        </h2>
        <p class="prose">
          A tool that records everything you see and hear is a serious
          commitment. Four things worth insisting on.
        </p>
        <ul class="criteria-list">
          {
            criteria.map((item) => (
              <li class="criteria-item">
                <span class="criteria-marker" aria-hidden="true">
                  ✓
                </span>
                <div class="criteria-text">
                  <span class="criteria-label">{item.label}</span>
                  <span class="criteria-detail">{item.detail}</span>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Comparison -->
      <section class="docs-section" aria-labelledby="comparison">
        <p class="kicker">// the field</p>
        <h2 class="section-heading" id="comparison">
          Mnema vs Screenpipe vs OpenRecall
        </h2>
        <p class="prose">
          All three keep your data local — the differences are in what you get
          out of the box, the license, and the price.
        </p>
        <div class="table-scroll">
          <table class="compare-table">
            <thead>
              <tr>
                <th scope="col"></th>
                {comparison.columns.map((col) => <th scope="col">{col}</th>)}
              </tr>
            </thead>
            <tbody>
              {
                comparison.rows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    {row.cells.map((cell, i) => (
                      <td class={i === 0 ? "cell-mnema" : undefined}>{cell}</td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="table-note">
          Competitor details reflect public information as of July 2026 —
          check each project directly before deciding.
        </p>
      </section>

      <!-- FAQ -->
      <section class="docs-section" aria-labelledby="faq">
        <p class="kicker">// questions</p>
        <h2 class="section-heading" id="faq">Frequently asked</h2>
        <dl class="faq-list">
          {
            faqs.map((item) => (
              <div class="faq-item">
                <dt>
                  <h3 class="faq-q">{item.q}</h3>
                </dt>
                <dd class="faq-a">{item.a}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- CTA -->
      <section class="docs-section cta" aria-labelledby="cta-heading">
        <p class="kicker">// get started</p>
        <h2 class="section-heading" id="cta-heading">
          Recall that works out of the box.
        </h2>
        <p class="prose">
          Download Mnema and build a private, searchable memory of your work —
          one you can scrub, search, and ask anything. Open source, free for
          30 days.
        </p>
        <a href={DOWNLOAD_URL} class="btn-primary">
          Download for {PLATFORM_LABEL.split(" · ")[0]}
          <span class="btn-platform">{PLATFORM_LABEL.split(" · ")[1]}</span>
        </a>
      </section>

      <!-- Page footer -->
      <footer class="docs-foot">
        <p class="docs-foot-line">
          // local-first · encrypted at rest · no account, no servers, no
          telemetry — your record never leaves your Mac.
        </p>
        <a href="/" class="docs-back">
          <span class="prompt" aria-hidden="true">&gt;</span>
          <span>Back to mnema</span>
        </a>
      </footer>
    </article>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={faqJsonLd} is:inline />
</Base>

<style>
  /* ---- Docs layout shell (same pattern as rewind-ai.astro) ---- */
  .docs {
    padding: calc(var(--space-2xl) + 3rem) var(--space-lg) var(--space-2xl);
  }

  .docs-col {
    max-width: 52rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  /* ---- Hero ---- */
  .docs-hero {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-xl);
  }

  .docs-title {
    font-family: var(--font-sans);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
    max-width: 24ch;
  }

  .docs-sub {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-base);
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: var(--space-md);
  }

  .docs-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  /* ---- Section shell ---- */
  .docs-section {
    margin-bottom: var(--space-2xl);
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
    max-width: 30ch;
  }

  .prose {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    font-size: var(--text-base);
    line-height: 1.75;
    max-width: 64ch;
  }

  .prose + .prose {
    margin-top: var(--space-md);
  }

  /* ---- Criteria ---- */
  .criteria-list {
    list-style: none;
    display: grid;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .criteria-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-sm);
    align-items: start;
  }

  .criteria-marker {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .criteria-text {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
  }

  .criteria-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    letter-spacing: 0.01em;
  }

  .criteria-detail {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.65;
  }

  /* ---- Comparison table ---- */
  .table-scroll {
    margin-top: var(--space-lg);
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .compare-table {
    width: 100%;
    min-width: 40rem;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .compare-table th,
  .compare-table td {
    padding: 0.65rem 0.85rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--border);
  }

  .compare-table tbody tr:last-child th,
  .compare-table tbody tr:last-child td {
    border-bottom: none;
  }

  .compare-table thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--fg);
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--border-strong);
  }

  .compare-table thead th:first-child {
    color: var(--fg-muted);
  }

  .compare-table tbody th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .compare-table td {
    font-family: var(--font-sans);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .compare-table td.cell-mnema {
    color: var(--fg);
  }

  .table-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    letter-spacing: 0.01em;
    margin-top: var(--space-sm);
    max-width: 70ch;
  }

  /* ---- FAQ ---- */
  .faq-list {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .faq-item {
    display: grid;
    gap: var(--space-xs);
  }

  .faq-q {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .faq-a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 62ch;
  }

  /* ---- CTA ---- */
  .cta .prose {
    margin-bottom: var(--space-md);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--bg);
    background: var(--accent);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition:
      box-shadow 0.3s var(--ease-out-quart),
      transform 0.3s var(--ease-out-quart),
      opacity 0.2s var(--ease-out-quart);
  }

  .btn-primary:hover {
    text-decoration: none;
    box-shadow: 0 0 28px var(--accent-glow);
    transform: translateY(-1px);
    opacity: 0.92;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-primary:hover {
      transform: none;
    }
  }

  .btn-platform {
    font-size: var(--text-xs);
    opacity: 0.7;
  }

  /* ---- Page footer ---- */
  .docs-foot {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
    display: grid;
    gap: var(--space-md);
  }

  .docs-foot-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    line-height: 1.7;
    letter-spacing: 0.01em;
    max-width: 70ch;
  }

  .docs-back {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s var(--ease-out-quart);
  }

  .docs-back:hover {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }

  .prompt {
    color: var(--accent);
  }
</style>
