---
import Base from "../layouts/Base.astro";
import TopBar from "../components/TopBar.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import TimelineRewind from "../components/TimelineRewind.astro";
import WhatItRemembers from "../components/WhatItRemembers.astro";
import AskAi from "../components/AskAi.astro";
import Insights from "../components/Insights.astro";
import Privacy from "../components/Privacy.astro";
import MoreFeatures from "../components/MoreFeatures.astro";
import AgentsPointer from "../components/AgentsPointer.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";
import { DOWNLOAD_URL } from "../config";

const appJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Mnema",
  operatingSystem: "macOS",
  applicationCategory: "UtilitiesApplication",
  description:
    "Mnema records your screen, audio, and activity into a private, searchable record you can scrub, search, and ask an AI about — all on your Mac.",
  url: "https://mnema.day",
  downloadUrl: DOWNLOAD_URL,
  offers: {
    "@type": "Offer",
    price: "69",
    priceCurrency: "USD",
  },
});
---

<Base>
  <script type="application/ld+json" set:html={appJsonLd} is:inline />
  <TopBar />
  <main>
    <Hero />
    <HowItWorks />
    <TimelineRewind />
    <WhatItRemembers />
    <AskAi />
    <Insights />
    <Privacy />
    <MoreFeatures />
    <AgentsPointer />
    <FinalCta />
  </main>
  <Footer />
</Base>
