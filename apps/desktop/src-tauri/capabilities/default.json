{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main, settings, and debug windows",
  "windows": ["main", "settings", "debug"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "clipboard-manager:allow-write-image",
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$DOWNLOAD/*" }]
    }
  ]
}
