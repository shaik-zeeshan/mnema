{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mnema",
  "version": "0.1.0",
  "identifier": "com.shaikzeeshan.mnema",
  "build": {
    "beforeDevCommand": "cargo build --manifest-path src-tauri/Cargo.toml --bin mnema_browser_integration_host && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cargo clean --manifest-path src-tauri/Cargo.toml && cargo build --manifest-path src-tauri/Cargo.toml --bin mnema_browser_integration_host --release && bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mnema"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../browser-extension",
      "resources/browser-integration-native-host.sh"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
