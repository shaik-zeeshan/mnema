{
  "name": "mnema",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=desktop",
    "build": "turbo run build --filter=desktop --cache=local:r",
    "check": "turbo run check --filter=desktop --cache=local:r",
    "tauri": "turbo run tauri --filter=desktop --",
    "dev:web": "turbo run dev --filter=web",
    "build:web": "turbo run build --filter=web",
    "check:web": "turbo run check --filter=web",
    "build:macos-local-sign": "./scripts/build-macos-local-sign.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
