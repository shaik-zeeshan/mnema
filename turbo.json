{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "build/**",
        ".svelte-kit/**",
        "dist/**"
      ]
    },
    "check": {
      "dependsOn": [
        "^check"
      ]
    },
    "tauri": {
      "cache": false,
      "passThroughEnv": [
        "MNEMA_SAVE_DIRECTORY",
        "MNEMA_APP_CONFIG_DIR",
        "MNEMA_CAPTURE_INDEX_KEY_DIR",
        "MNEMA_AI_PROVIDER_KEY_DIR",
        "MNEMA_LICENSE_ENFORCE",
        "MNEMA_TRIAL_RESET",
        "MNEMA_TRIAL_LEN_MS",
        "MNEMA_DEV_CRL_URL",
        "MNEMA_CRL_URL",
        "MNEMA_DEV_ACTIVATION_URL",
        "MNEMA_ACTIVATION_URL",
        "MNEMA_LICENSE_PUBLIC_KEY",
        "VITE_LICENSE_CHECKOUT_URL",
        "VITE_RENEWAL_CHECKOUT_URL"
      ]
    }
  }
}
